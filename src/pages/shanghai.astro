---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'л„ӨмҳЁ мғҒн•ҳмқҙ вҖ” мһ…мІҙ мӮ¬мІңм„ұ (м–ҙл ӨмӣҖ) | кІҢмһ„мӣ”л“ң7';
const description =
	'лё”лЎқмқҙ 3мёөмңјлЎң мҢ“мқё мһ…мІҙ мӮ¬мІңм„ұ(мғҒн•ҳмқҙ) нҚјмҰҗ. мң„к°Җ лҚ®мҳҖкұ°лӮҳ м–‘мҳҶмқҙ л§үнһҢ нғҖмқјмқҖ лӘ» л№јлҠ” м •нҶө к·ңм№ҷ, 92нғҖмқј н•ҳл“ң лӘЁл“ң. л¬ҙлЈҢ В· м„Өм№ҳ м—ҶмқҢ.';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div id="shgame">
				<section class="game-hero">
					<span class="tag">PLAY В· лҜёлӢҲкІҢмһ„ В· н•ҳл“ң</span>
					<h1>рҹҸҜ <span class="neon">л„ӨмҳЁ мғҒн•ҳмқҙ</span></h1>
					<p class="lead"><strong>3мёөмңјлЎң мҢ“мқё</strong> лё”лЎқ мӮ°м—җм„ң к°ҷмқҖ к·ёлҰј л‘җ к°ңлҘј л№јлӮҙм„ёмҡ”. мң„к°Җ лҚ®мҳҖкұ°лӮҳ <strong>м–‘мҳҶмқҙ лӢӨ л§үнһҢ лё”лЎқмқҖ лӘ» ләҚлӢҲлӢӨ!</strong></p>
				</section>

				<div class="hud">
					<div class="hud-item">м җмҲҳ <strong id="score">0</strong></div>
					<div class="hud-item">мөңкі  <strong id="best">0</strong></div>
					<div class="hud-item">лӮЁмқҖ м§қ <strong id="pairs">46</strong></div>
					<div class="hud-item">мӢңк°„ <strong id="time">8:00</strong></div>
					<button class="hud-item tool-btn" id="hintBtn" type="button">рҹ’Ў нһҢнҠё</button>
					<button class="hud-item tool-btn" id="shuffleBtn" type="button">рҹ”Җ м„һкё°</button>
					<button class="hud-item tool-btn" id="soundBtn" type="button" aria-label="нҡЁкіјмқҢ мјңкё°/лҒ„кё°">рҹ”Ҡ</button>
				</div>
				<div class="timebar"><div class="timebar-fill" id="timebar"></div></div>

				<div class="stage">
					<canvas id="board" width="580" height="380" aria-label="л„ӨмҳЁ мғҒн•ҳмқҙ ліҙл“ң"></canvas>
					<div class="overlay" id="overlay">
						<h2 id="ov-title">л„ӨмҳЁ мғҒн•ҳмқҙ</h2>
						<p id="ov-sub">кәјлӮј мҲҳ мһҲлҠ” лё”лЎқл§Ң л°қкІҢ л№ӣлӮҳмҡ”</p>
						<button class="btn" id="startBtn" type="button">кІҢмһ„ мӢңмһ‘</button>
						<button class="btn-ghost btn" id="shareBtn" type="button" hidden>м җмҲҳ кіөмң </button>
					</div>
				</div>

				<section class="howto">
					<h2>к·ңм№ҷ</h2>
					<ul>
						<li>лё”лЎқмқҙ <strong>3мёө н”јлқјлҜёл“ң</strong>лЎң мҢ“м—¬ мһҲмҠөлӢҲлӢӨ. к°ҷмқҖ к·ёлҰј л‘җ к°ңлҘј м°ЁлЎҖлЎң нғӯн•ҳл©ҙ мӮ¬лқјм§‘лӢҲлӢӨ.</li>
						<li>лә„ мҲҳ мһҲлҠ” лё”лЎқ мЎ°кұҙ: <strong>л°”лЎң мң„м—җ лё”лЎқмқҙ м—Ҷкі </strong>, к°ҷмқҖ мёөм—җм„ң <strong>мҷјмӘҪмқҙлӮҳ мҳӨлҘёмӘҪ мӨ‘ н•ңмӘҪмқҙ л№„м–ҙ</strong> мһҲм–ҙм•ј н•©лӢҲлӢӨ.</li>
						<li>л§үнһҢ лё”лЎқмқҖ м–ҙл‘ЎкІҢ н‘ңмӢңлҗ©лӢҲлӢӨ. мң„мёөмқ„ кұ·м–ҙлӮҙл©ҙ м•„лһҳмёөмқҙ м—ҙлҰҪлӢҲлӢӨ.</li>
						<li>м§қ н•ҳлӮҳ 10м җ, 8л¶„ м•Ҳм—җ 92к°ңлҘј лӢӨ л№јл©ҙ лӮЁмқҖ мӢңк°„л§ҢнҒј ліҙл„ҲмҠӨ. лә„ м§қмқҙ м—Ҷмңјл©ҙ мһҗлҸҷмңјлЎң м„һмһ…лӢҲлӢӨ.</li>
					</ul>
					<h2>кіөлһө нҢҒ</h2>
					<ul>
						<li><strong>л§Ё мң—мёөкіј кёҙ мӨ„мқҳ м–‘лҒқл¶Җн„°</strong> м •лҰ¬н•ҳм„ёмҡ”. м•„лһҳк°Җ л№ЁлҰ¬ м—ҙлҰҪлӢҲлӢӨ.</li>
						<li>к°ҷмқҖ к·ёлҰјмқҙ <strong>кІ№міҗ мҢ“м—¬</strong> мһҲмңјл©ҙ(мң„В·м•„лһҳ) мң„ кІғл¶Җн„° л№јм•ј м•„лһҳ кІғмқ„ м“ё мҲҳ мһҲмҠөлӢҲлӢӨ.</li>
						<li>ліҙмқҙлҠ” м§қмқ„ л¬ҙмЎ°кұҙ л№јм§Җ л§җкі , м–ҙлҠҗ мӘҪ лё”лЎқмқ„ л№јм•ј мғҲ лё”лЎқмқҙ м—ҙлҰ¬лҠ”м§Җ н•ң мҲҳ м•һмқ„ ліҙм„ёмҡ”.</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const canvas = document.getElementById('board');
				const ctx = canvas.getContext('2d');
				const CELL = 50, LIFT = 8, MX = 40, MY = 46; // мёөлӢ№ мң„лЎң л“Өм–ҙмҳ¬лҰ¬лҠ” н”Ҫм…Җ
				const ROWS = 6, COLS = 10;
				// 3мёө н”јлқјлҜёл“ң: мёөлі„ нғҖмқј лІ”мң„(мҙқ 60+24+8 = 92нғҖмқј = 23мӢ¬ліјГ—4)
				const LAYOUT = [
					{r0: 0, r1: 5, c0: 0, c1: 9},
					{r0: 1, r1: 4, c0: 2, c1: 7},
					{r0: 2, r1: 3, c0: 3, c1: 6},
				];
				const SYMBOLS = ['рҹҚҺ','рҹҚҢ','рҹҚҮ','рҹҚү','рҹҚ“','рҹҘқ','рҹҚ‘','рҹҚ’','рҹҚҚ','рҹҘ•','рҹҗ¶','рҹҗұ','рҹҗ°','рҹҰҠ','рҹҗј','рҹҗё','рҹҗө','рҹҗ·','вӯҗ','рҹҢҷ','рҹ””','вқӨпёҸ','рҹҚҖ'];
				const scoreEl = document.getElementById('score');
				const bestEl = document.getElementById('best');
				const pairsEl = document.getElementById('pairs');
				const timeEl = document.getElementById('time');
				const timebar = document.getElementById('timebar');
				const overlay = document.getElementById('overlay');
				const ovTitle = document.getElementById('ov-title');
				const ovSub = document.getElementById('ov-sub');
				const startBtn = document.getElementById('startBtn');
				const shareBtn = document.getElementById('shareBtn');
				const hintBtn = document.getElementById('hintBtn');
				const shuffleBtn = document.getElementById('shuffleBtn');
				const BEST_KEY = 'gw7_shanghai_best';
				const GAME_SEC = 480;

				// --- sound ---
				const soundBtn = document.getElementById('soundBtn');
				const SOUND_KEY = 'gw7_shanghai_sound';
				let soundOn = localStorage.getItem(SOUND_KEY) !== '0';
				let audioCtx = null;
				const updateSoundBtn = () => { soundBtn.textContent = soundOn ? 'рҹ”Ҡ' : 'рҹ”Ү'; };
				updateSoundBtn();
				soundBtn.addEventListener('click', () => {
					soundOn = !soundOn;
					localStorage.setItem(SOUND_KEY, soundOn ? '1' : '0');
					updateSoundBtn();
					if (soundOn) tone(520, 0.08, 'sine', 0.15);
				});
				function ac() {
					if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
					if (audioCtx.state === 'suspended') audioCtx.resume();
					return audioCtx;
				}
				function tone(freq, dur, type, vol, when, slide) {
					if (!soundOn) return;
					try {
						const a = ac();
						const t0 = a.currentTime + (when || 0);
						const o = a.createOscillator();
						const g = a.createGain();
						o.type = type || 'sine';
						o.frequency.setValueAtTime(freq, t0);
						if (slide) o.frequency.exponentialRampToValueAtTime(Math.max(40, freq + slide), t0 + dur);
						g.gain.setValueAtTime(vol || 0.15, t0);
						g.gain.exponentialRampToValueAtTime(0.001, t0 + dur);
						o.connect(g).connect(a.destination);
						o.start(t0);
						o.stop(t0 + dur + 0.02);
					} catch {}
				}
				const sndSelect = () => tone(500, 0.05, 'sine', 0.09, 0, 100);
				const sndMatch = () => { tone(660, 0.1, 'triangle', 0.18, 0, 200); tone(990, 0.09, 'sine', 0.1, 0.03, 150); };
				const sndInvalid = () => tone(160, 0.1, 'square', 0.06, 0, -50);
				const sndLocked = () => tone(120, 0.09, 'square', 0.05, 0, -20);
				const sndShuffle = () => [0, 0.05, 0.1].forEach((d) => tone(300 + Math.random() * 200, 0.06, 'sine', 0.07, d, 80));
				const sndWin = () => [523, 659, 784, 1047, 1319].forEach((f, i) => tone(f, 0.22, 'triangle', 0.16, i * 0.12, 40));
				const sndOver = () => { tone(440, 0.18, 'sawtooth', 0.12, 0, -160); tone(330, 0.24, 'sawtooth', 0.1, 0.15, -120); };

				// --- state ---
				// L[l][r][c] = мӢ¬ліј мқёлҚұмҠӨ | null
				let L, score, pairsLeft, timeLeft, timerId, raf, running = false;
				let selected = null, fading = [], hintPair = null, hintT0 = 0, toast = null;
				let best = Number(localStorage.getItem(BEST_KEY) || 0);
				bestEl.textContent = best;
				const fmt = (s) => Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0');

				const inLayout = (l, r, c) => {
					const b = LAYOUT[l];
					return !!b && r >= b.r0 && r <= b.r1 && c >= b.c0 && c <= b.c1;
				};
				const at = (l, r, c) => (inLayout(l, r, c) ? L[l][r][c] : null);

				function isFree(l, r, c) {
					if (at(l, r, c) === null) return false;
					if (at(l + 1, r, c) !== null) return false; // мң„к°Җ лҚ®мһ„
					const left = at(l, r, c - 1), right = at(l, r, c + 1);
					return left === null || right === null; // н•ңмӘҪ мҳҶмқҙ м—ҙл Ө мһҲм–ҙм•ј н•Ё
				}

				function totalTiles() {
					return LAYOUT.reduce((s, b) => s + (b.r1 - b.r0 + 1) * (b.c1 - b.c0 + 1), 0);
				}

				function buildBoard() {
					const total = totalTiles(); // 92
					const bag = [];
					for (let i = 0; i < total / 4; i++) bag.push(i, i, i, i);
					for (let i = bag.length - 1; i > 0; i--) {
						const j = Math.floor(Math.random() * (i + 1));
						[bag[i], bag[j]] = [bag[j], bag[i]];
					}
					L = LAYOUT.map(() => Array.from({length: ROWS}, () => Array(COLS).fill(null)));
					let k = 0;
					LAYOUT.forEach((b, l) => {
						for (let r = b.r0; r <= b.r1; r++)
							for (let c = b.c0; c <= b.c1; c++) L[l][r][c] = bag[k++];
					});
					if (!findFreePair()) shuffleBoard(false);
				}

				function freeTiles() {
					const out = [];
					LAYOUT.forEach((b, l) => {
						for (let r = b.r0; r <= b.r1; r++)
							for (let c = b.c0; c <= b.c1; c++)
								if (isFree(l, r, c)) out.push({l, r, c, v: L[l][r][c]});
					});
					return out;
				}

				function findFreePair() {
					const bySym = {};
					for (const t of freeTiles()) (bySym[t.v] = bySym[t.v] || []).push(t);
					for (const list of Object.values(bySym))
						if (list.length >= 2) return [list[0], list[1]];
					return null;
				}

				function shuffleBoard(playSound) {
					const pos = [], vals = [];
					LAYOUT.forEach((b, l) => {
						for (let r = b.r0; r <= b.r1; r++)
							for (let c = b.c0; c <= b.c1; c++)
								if (L[l][r][c] !== null) { pos.push([l, r, c]); vals.push(L[l][r][c]); }
					});
					let guard = 0;
					do {
						for (let i = vals.length - 1; i > 0; i--) {
							const j = Math.floor(Math.random() * (i + 1));
							[vals[i], vals[j]] = [vals[j], vals[i]];
						}
						pos.forEach(([l, r, c], i) => { L[l][r][c] = vals[i]; });
					} while (!findFreePair() && ++guard < 80);
					if (playSound !== false) sndShuffle();
					selected = null;
				}

				function startGame() {
					buildBoard();
					score = 0;
					pairsLeft = totalTiles() / 2;
					timeLeft = GAME_SEC;
					selected = null; fading = []; hintPair = null; toast = null;
					scoreEl.textContent = '0';
					pairsEl.textContent = pairsLeft;
					timeEl.textContent = fmt(timeLeft);
					timebar.style.width = '100%';
					overlay.classList.add('hidden');
					running = true;
					clearInterval(timerId);
					timerId = setInterval(() => {
						timeLeft--;
						timeEl.textContent = fmt(Math.max(0, timeLeft));
						timebar.style.width = (Math.max(0, timeLeft) / GAME_SEC) * 100 + '%';
						if (timeLeft <= 0) endGame(false);
					}, 1000);
					cancelAnimationFrame(raf);
					raf = requestAnimationFrame(loop);
				}

				function endGame(win) {
					clearInterval(timerId);
					running = false;
					if (win) {
						score += timeLeft;
						scoreEl.textContent = score;
						sndWin();
					} else sndOver();
					if (score > best) {
						best = score;
						localStorage.setItem(BEST_KEY, best);
						bestEl.textContent = best;
					}
					ovTitle.textContent = win ? 'рҹҺү мҳ¬ нҒҙлҰ¬м–ҙ!' : 'нғҖмһ„ м—…!';
					ovSub.textContent = win
						? `м җмҲҳ ${score} (мӢңк°„ ліҙл„ҲмҠӨ +${timeLeft}) В· мөңкі  ${best}`
						: `м җмҲҳ ${score} В· лӮЁмқҖ м§қ ${pairsLeft} В· мөңкі  ${best}`;
					startBtn.textContent = 'лӢӨмӢң н•ҳкё°';
					shareBtn.hidden = false;
					setTimeout(() => overlay.classList.remove('hidden'), win ? 900 : 400);
				}

				function tapTile(l, r, c) {
					if (!running) return;
					const v = at(l, r, c);
					if (v === null) { selected = null; return; }
					if (!isFree(l, r, c)) { sndLocked(); return; }
					if (selected && selected.l === l && selected.r === r && selected.c === c) { selected = null; return; }
					if (!selected) { selected = {l, r, c}; sndSelect(); return; }
					if (at(selected.l, selected.r, selected.c) !== v) { sndInvalid(); selected = {l, r, c}; return; }
					// л§Өм№ҳ!
					fading.push({l: selected.l, r: selected.r, c: selected.c, v, t0: performance.now()});
					fading.push({l, r, c, v, t0: performance.now()});
					L[selected.l][selected.r][selected.c] = null;
					L[l][r][c] = null;
					selected = null;
					hintPair = null;
					score += 10;
					pairsLeft--;
					scoreEl.textContent = score;
					pairsEl.textContent = pairsLeft;
					sndMatch();
					if (pairsLeft === 0) return endGame(true);
					if (!findFreePair()) {
						shuffleBoard();
						toast = {text: 'лә„ м§қмқҙ м—Ҷм–ҙ м„һм—Ҳм–ҙмҡ”!', t0: performance.now()};
					}
				}

				hintBtn.addEventListener('click', () => {
					if (!running) return;
					const p = findFreePair();
					if (p) { hintPair = p; hintT0 = performance.now(); sndSelect(); }
				});
				shuffleBtn.addEventListener('click', () => {
					if (!running) return;
					shuffleBoard();
					toast = {text: 'м„һм—Ҳм–ҙмҡ”!', t0: performance.now()};
				});

				// --- rendering ---
				const tx = (l, c) => MX + c * CELL - l * LIFT;
				const ty = (l, r) => MY + r * CELL - l * LIFT;

				function drawTile(l, r, c, v, opts) {
					const {scale = 1, glow = false, dim = false, alpha = 1} = opts || {};
					const x = tx(l, c), y = ty(l, r);
					const cxp = x + CELL / 2, cyp = y + CELL / 2;
					ctx.save();
					ctx.globalAlpha = alpha;
					ctx.translate(cxp, cyp);
					ctx.scale(scale, scale);
					ctx.translate(-cxp, -cyp);
					const pad = 2;
					// л‘җк»ҳ(мһ…мІҙк°җ): мҳӨлҘёмӘҪВ·м•„лһҳ м–ҙл‘җмҡҙ л©ҙ
					ctx.fillStyle = '#0a0d15';
					ctx.beginPath();
					ctx.roundRect(x + pad + 4, y + pad + 4, CELL - pad * 2, CELL - pad * 2, 9);
					ctx.fill();
					// мң—л©ҙ
					const topBright = 0.16 + l * 0.1; // мң„мёөмқјмҲҳлЎқ л°қкІҢ
					ctx.fillStyle = dim ? '#141926' : `rgba(58, 74, 114, ${0.75 + l * 0.12})`;
					ctx.strokeStyle = glow ? '#3ef58b' : (dim ? 'rgba(90,110,160,0.2)' : 'rgba(140,170,235,' + (0.3 + topBright) + ')');
					ctx.lineWidth = glow ? 2.5 : 1;
					if (glow) { ctx.shadowColor = '#3ef58b'; ctx.shadowBlur = 14; }
					ctx.beginPath();
					ctx.roundRect(x + pad, y + pad, CELL - pad * 2, CELL - pad * 2, 9);
					ctx.fill();
					ctx.stroke();
					ctx.shadowBlur = 0;
					ctx.globalAlpha = alpha * (dim ? 0.42 : 1);
					ctx.font = `${CELL * 0.52}px serif`;
					ctx.textAlign = 'center';
					ctx.textBaseline = 'middle';
					ctx.fillText(SYMBOLS[v], cxp, cyp + CELL * 0.02);
					ctx.restore();
				}

				function loop(t) {
					ctx.fillStyle = '#0b0e14';
					ctx.fillRect(0, 0, canvas.width, canvas.height);
					// мёө мҲңм„ңлҢҖлЎң(м•„лһҳвҶ’мң„) к·ёл Өм„ң кІ№м№Ё н‘ңнҳ„
					LAYOUT.forEach((b, l) => {
						for (let r = b.r0; r <= b.r1; r++)
							for (let c = b.c0; c <= b.c1; c++) {
								const v = L[l][r][c];
								if (v === null) continue;
								const free = isFree(l, r, c);
								const isSel = selected && selected.l === l && selected.r === r && selected.c === c;
								const isHint = hintPair && t - hintT0 < 2000 &&
									hintPair.some((p) => p.l === l && p.r === r && p.c === c);
								const pulse = isSel ? 1 + 0.04 * Math.sin(t / 120) : 1;
								drawTile(l, r, c, v, {scale: pulse, glow: isSel || isHint, dim: !free});
							}
					});
					// мӮ¬лқјм§ҖлҠ” нғҖмқј
					for (let i = fading.length - 1; i >= 0; i--) {
						const f = fading[i];
						const k = (t - f.t0) / 220;
						if (k >= 1) { fading.splice(i, 1); continue; }
						drawTile(f.l, f.r, f.c, f.v, {scale: 1 + k * 0.35, glow: true, alpha: 1 - k});
					}
					// нҶ мҠӨнҠё
					if (toast) {
						const k = (t - toast.t0) / 1400;
						if (k >= 1) toast = null;
						else {
							ctx.save();
							ctx.globalAlpha = 1 - k;
							ctx.fillStyle = '#ffd166';
							ctx.shadowColor = '#ffd166';
							ctx.shadowBlur = 12;
							ctx.font = '800 22px system-ui, sans-serif';
							ctx.textAlign = 'center';
							ctx.fillText(toast.text, canvas.width / 2, canvas.height / 2);
							ctx.restore();
						}
					}
					if (running || fading.length) raf = requestAnimationFrame(loop);
				}

				// --- input: мң„мёөл¶Җн„° нһҲнҠё н…ҢмҠӨнҠё ---
				canvas.addEventListener('pointerdown', (e) => {
					if (!running) return;
					e.preventDefault();
					const rect = canvas.getBoundingClientRect();
					const x = ((e.clientX - rect.left) / rect.width) * canvas.width;
					const y = ((e.clientY - rect.top) / rect.height) * canvas.height;
					for (let l = LAYOUT.length - 1; l >= 0; l--) {
						const b = LAYOUT[l];
						const c = Math.floor((x - MX + l * LIFT) / CELL);
						const r = Math.floor((y - MY + l * LIFT) / CELL);
						if (r >= b.r0 && r <= b.r1 && c >= b.c0 && c <= b.c1 && L[l][r][c] !== null) {
							tapTile(l, r, c);
							return;
						}
					}
				});

				startBtn.addEventListener('click', startGame);
				shareBtn.addEventListener('click', async () => {
					const text = `л„ӨмҳЁ мғҒн•ҳмқҙ(мһ…мІҙ мӮ¬мІңм„ұ) ${score}м җ! лӮҳлҘј мқҙкІЁлҙҗ рҹ‘ү ${location.href}`;
					try {
						await navigator.clipboard.writeText(text);
						shareBtn.textContent = 'ліөмӮ¬ мҷ„лЈҢ!';
					} catch {
						shareBtn.textContent = text;
					}
					setTimeout(() => (shareBtn.textContent = 'м җмҲҳ кіөмң '), 1600);
				});

				// мӢңмһ‘ м „ лҜёлҰ¬ліҙкё°
				buildBoard();
				(function preview() {
					ctx.fillStyle = '#0b0e14';
					ctx.fillRect(0, 0, canvas.width, canvas.height);
					LAYOUT.forEach((b, l) => {
						for (let r = b.r0; r <= b.r1; r++)
							for (let c = b.c0; c <= b.c1; c++)
								if (L[l][r][c] !== null) drawTile(l, r, c, L[l][r][c], {dim: !isFree(l, r, c)});
					});
				})();

				// test hook
				window.__sh = {
					pairsLeft: () => pairsLeft,
					score: () => score,
					running: () => running,
					findFreePair,
					freeTiles,
					tap: (l, r, c) => tapTile(l, r, c),
					at: (l, r, c) => at(l, r, c),
					isFree,
				};
			})();
		</script>
	</body>
</html>

