---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = '야옹이 미로 찾기 — 아이용 무료 미로 게임 | 게임월드7';
const description =
	'5살 아이도 혼자 할 수 있는 고양이 미로 찾기 게임. 야옹이를 움직여 물고기를 찾아주세요! 실패도 시간제한도 없는 유아용 두뇌 놀이. 무료 · 설치 없음.';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div id="mazegame">
				<section class="game-hero">
					<span class="tag">PLAY · 키즈</span>
					<h1>😺 <span class="neon">야옹이 미로 찾기</span></h1>
					<p class="lead">야옹이가 배고파요! 미로를 지나 <strong>물고기 🐟</strong>를 찾아주세요.</p>
				</section>

				<div class="hud">
					<div class="hud-item">미로 <strong id="level">1</strong></div>
					<div class="hud-item">클리어 <strong id="cleared">0</strong>개</div>
					<button class="hud-item sound-btn" id="soundBtn" type="button" aria-label="효과음 켜기/끄기">🔊</button>
				</div>

				<div class="stage">
					<canvas id="board" width="480" height="480" aria-label="고양이 미로 찾기 보드"></canvas>
					<div class="overlay" id="overlay">
						<div class="ov-emoji" id="ov-emoji">😺</div>
						<h2 id="ov-title">야옹이 미로 찾기</h2>
						<p id="ov-sub">화살표를 눌러 야옹이를 움직여요</p>
						<button class="btn big-btn" id="startBtn" type="button">시작!</button>
					</div>
				</div>

				<div class="dpad" aria-label="이동 버튼">
					<button type="button" data-dir="up" aria-label="위로">⬆️</button>
					<div class="dpad-mid">
						<button type="button" data-dir="left" aria-label="왼쪽으로">⬅️</button>
						<button type="button" data-dir="down" aria-label="아래로">⬇️</button>
						<button type="button" data-dir="right" aria-label="오른쪽으로">➡️</button>
					</div>
				</div>

				<section class="howto">
					<h2>부모님께</h2>
					<ul>
						<li>미취학 아이용으로 만든 미로 게임입니다. <strong>실패·시간제한·광고성 팝업이 없고</strong>, 물고기를 찾으면 칭찬과 폭죽만 나옵니다.</li>
						<li>이동은 <strong>큰 화살표 버튼</strong>, 키보드 방향키, 화면 밀기(스와이프) 모두 됩니다.</li>
						<li>미로는 매판 자동으로 새로 만들어지고, 클리어할수록 조금씩 커집니다(6×6 → 10×10).</li>
						<li>지나온 길에 발자국이 남아서 아이가 스스로 길을 정리하며 공간 감각을 익힐 수 있습니다.</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const canvas = document.getElementById('board');
				const ctx = canvas.getContext('2d');
				const SIZE = canvas.width;
				const levelEl = document.getElementById('level');
				const clearedEl = document.getElementById('cleared');
				const overlay = document.getElementById('overlay');
				const ovEmoji = document.getElementById('ov-emoji');
				const ovTitle = document.getElementById('ov-title');
				const ovSub = document.getElementById('ov-sub');
				const startBtn = document.getElementById('startBtn');
				const CLEAR_KEY = 'gw7_maze_cleared';
				const WALLS = ['#00e5ff', '#ff8fd0', '#ffd166', '#3ef58b', '#b78bff'];
				const PRAISE = [
					['🎉', '찾았다! 참 잘했어요!'],
					['⭐', '와, 최고예요!'],
					['😻', '야옹이가 신났어요!'],
					['💖', '정말 대단해요!'],
					['🏆', '미로 박사님이네요!'],
				];

				// --- sound ---
				const soundBtn = document.getElementById('soundBtn');
				const SOUND_KEY = 'gw7_maze_sound';
				let soundOn = localStorage.getItem(SOUND_KEY) !== '0';
				let audioCtx = null;
				const updateSoundBtn = () => { soundBtn.textContent = soundOn ? '🔊' : '🔇'; };
				updateSoundBtn();
				soundBtn.addEventListener('click', () => {
					soundOn = !soundOn;
					localStorage.setItem(SOUND_KEY, soundOn ? '1' : '0');
					updateSoundBtn();
					if (soundOn) tone(660, 0.08, 'sine', 0.15);
				});
				function ac() {
					if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
					if (audioCtx.state === 'suspended') audioCtx.resume();
					return audioCtx;
				}
				function tone(freq, dur, type, vol, when, slide) {
					if (!soundOn) return;
					try {
						const a = ac();
						const t0 = a.currentTime + (when || 0);
						const o = a.createOscillator();
						const g = a.createGain();
						o.type = type || 'sine';
						o.frequency.setValueAtTime(freq, t0);
						if (slide) o.frequency.exponentialRampToValueAtTime(Math.max(40, freq + slide), t0 + dur);
						g.gain.setValueAtTime(vol || 0.15, t0);
						g.gain.exponentialRampToValueAtTime(0.001, t0 + dur);
						o.connect(g).connect(a.destination);
						o.start(t0);
						o.stop(t0 + dur + 0.02);
					} catch {}
				}
				const sndStep = () => tone(420, 0.05, 'sine', 0.08, 0, 120);
				const sndBump = () => tone(140, 0.08, 'sine', 0.06, 0, -30);
				const sndWin = () => {
					[523, 659, 784, 1047].forEach((f, i) => tone(f, 0.22, 'triangle', 0.16, i * 0.14, 40));
					tone(1319, 0.4, 'sine', 0.1, 0.56, -80);
				};

				// --- state ---
				let N, cells, cat, goal, level, moving, won;
				let trail, confetti = [], raf, catBob = 0, queued = null;
				let cleared = Number(localStorage.getItem(CLEAR_KEY) || 0);
				clearedEl.textContent = cleared;
				level = 1;

				const DIRS = {up: [-1, 0, 0], right: [0, 1, 1], down: [1, 0, 2], left: [0, -1, 3]};
				const OPP = [2, 3, 0, 1];

				function genMaze(n) {
					// walls: [top, right, bottom, left]
					const g = Array.from({length: n}, () =>
						Array.from({length: n}, () => ({w: [true, true, true, true], v: false})),
					);
					const stack = [[0, 0]];
					g[0][0].v = true;
					while (stack.length) {
						const [r, c] = stack[stack.length - 1];
						const opts = Object.values(DIRS)
							.map(([dr, dc, wi]) => [r + dr, c + dc, wi])
							.filter(([nr, nc]) => nr >= 0 && nc >= 0 && nr < n && nc < n && !g[nr][nc].v);
						if (!opts.length) { stack.pop(); continue; }
						const [nr, nc, wi] = opts[Math.floor(Math.random() * opts.length)];
						g[r][c].w[wi] = false;
						g[nr][nc].w[OPP[wi]] = false;
						g[nr][nc].v = true;
						stack.push([nr, nc]);
					}
					return g;
				}

				function farthestCell(g, n, from) {
					const dist = Array.from({length: n}, () => Array(n).fill(-1));
					dist[from.r][from.c] = 0;
					const q = [from];
					let far = from;
					while (q.length) {
						const {r, c} = q.shift();
						if (dist[r][c] > dist[far.r][far.c]) far = {r, c};
						Object.values(DIRS).forEach(([dr, dc, wi]) => {
							const nr = r + dr, nc = c + dc;
							if (nr >= 0 && nc >= 0 && nr < n && nc < n && !g[r][c].w[wi] && dist[nr][nc] < 0) {
								dist[nr][nc] = dist[r][c] + 1;
								q.push({r: nr, c: nc});
							}
						});
					}
					return far;
				}

				function newMaze() {
					N = Math.min(10, 5 + Math.ceil(level / 2)); // 6,7,7,8,8,9,9,10...
					cells = genMaze(N);
					cat = {r: 0, c: 0, px: 0, py: 0}; // px,py = pixel offset while sliding
					goal = farthestCell(cells, N, {r: 0, c: 0});
					trail = new Set(['0,0']);
					moving = null;
					queued = null;
					won = false;
					confetti = [];
					levelEl.textContent = level;
				}

				function tryMove(dir) {
					if (won || !DIRS[dir]) return;
					if (moving) { queued = dir; return; } // 연타해도 안 씹히게 큐잉
					const [dr, dc, wi] = DIRS[dir];
					if (cells[cat.r][cat.c].w[wi]) { sndBump(); return; }
					moving = {dr, dc, k: 0};
					sndStep();
				}

				function winMaze() {
					won = true;
					cleared++;
					localStorage.setItem(CLEAR_KEY, cleared);
					clearedEl.textContent = cleared;
					sndWin();
					const cell = SIZE / N;
					for (let i = 0; i < 90; i++) {
						confetti.push({
							x: Math.random() * SIZE, y: -20 - Math.random() * SIZE * 0.5,
							vy: 1.5 + Math.random() * 2.5, vx: (Math.random() - 0.5) * 1.4,
							color: WALLS[Math.floor(Math.random() * WALLS.length)],
							r: 3 + Math.random() * 4, rot: Math.random() * Math.PI,
						});
					}
					const [emo, msg] = PRAISE[Math.floor(Math.random() * PRAISE.length)];
					setTimeout(() => {
						ovEmoji.textContent = emo;
						ovTitle.textContent = msg;
						ovSub.textContent = `지금까지 미로 ${cleared}개 클리어!`;
						startBtn.textContent = '다음 미로 🐾';
						overlay.classList.remove('hidden');
					}, 1400);
				}

				// --- rendering ---
				function draw(t) {
					const cell = SIZE / N;
					const wallColor = WALLS[(level - 1) % WALLS.length];
					ctx.fillStyle = '#0b0e14';
					ctx.fillRect(0, 0, SIZE, SIZE);

					// trail paw dots
					ctx.save();
					ctx.fillStyle = 'rgba(255,255,255,0.13)';
					trail.forEach((key) => {
						const [r, c] = key.split(',').map(Number);
						ctx.beginPath();
						ctx.arc((c + 0.5) * cell, (r + 0.5) * cell, cell * 0.08, 0, Math.PI * 2);
						ctx.fill();
					});
					ctx.restore();

					// goal glow
					const pulse = 1 + 0.08 * Math.sin(t / 260);
					ctx.save();
					ctx.shadowColor = '#ffd166';
					ctx.shadowBlur = 18;
					ctx.font = `${cell * 0.62 * pulse}px serif`;
					ctx.textAlign = 'center';
					ctx.textBaseline = 'middle';
					ctx.fillText('🐟', (goal.c + 0.5) * cell, (goal.r + 0.55) * cell);
					ctx.restore();

					// walls (rounded neon)
					ctx.save();
					ctx.strokeStyle = wallColor;
					ctx.shadowColor = wallColor;
					ctx.shadowBlur = 8;
					ctx.lineWidth = Math.max(4, cell * 0.09);
					ctx.lineCap = 'round';
					for (let r = 0; r < N; r++)
						for (let c = 0; c < N; c++) {
							const x = c * cell, y = r * cell;
							const w = cells[r][c].w;
							ctx.beginPath();
							if (w[0]) { ctx.moveTo(x, y); ctx.lineTo(x + cell, y); }
							if (w[3]) { ctx.moveTo(x, y); ctx.lineTo(x, y + cell); }
							if (r === N - 1 && w[2]) { ctx.moveTo(x, y + cell); ctx.lineTo(x + cell, y + cell); }
							if (c === N - 1 && w[1]) { ctx.moveTo(x + cell, y); ctx.lineTo(x + cell, y + cell); }
							ctx.stroke();
						}
					ctx.restore();

					// cat (with slide animation + bob)
					catBob = Math.sin(t / 300) * cell * 0.03;
					let cx = (cat.c + 0.5) * cell, cy = (cat.r + 0.5) * cell;
					if (moving) {
						cx += moving.dc * cell * moving.k;
						cy += moving.dr * cell * moving.k;
					}
					ctx.save();
					ctx.font = `${cell * 0.68}px serif`;
					ctx.textAlign = 'center';
					ctx.textBaseline = 'middle';
					ctx.fillText('😺', cx, cy + catBob + cell * 0.04);
					ctx.restore();

					// confetti
					for (let i = confetti.length - 1; i >= 0; i--) {
						const p = confetti[i];
						p.y += p.vy; p.x += p.vx; p.rot += 0.08;
						if (p.y > SIZE + 20) { confetti.splice(i, 1); continue; }
						ctx.save();
						ctx.translate(p.x, p.y);
						ctx.rotate(p.rot);
						ctx.fillStyle = p.color;
						ctx.shadowColor = p.color;
						ctx.shadowBlur = 6;
						ctx.fillRect(-p.r, -p.r / 2, p.r * 2, p.r);
						ctx.restore();
					}
				}

				let lastT = 0;
				function loop(t) {
					const dt = lastT ? Math.min(50, t - lastT) : 16;
					lastT = t;
					if (moving) {
						moving.k += dt / 110;
						if (moving.k >= 1) {
							cat.r += moving.dr;
							cat.c += moving.dc;
							moving = null;
							trail.add(cat.r + ',' + cat.c);
							if (cat.r === goal.r && cat.c === goal.c) winMaze();
							else if (queued) { const q = queued; queued = null; tryMove(q); }
						}
					}
					draw(t);
					raf = requestAnimationFrame(loop);
				}

				// --- input ---
				document.addEventListener('keydown', (e) => {
					const map = {ArrowUp: 'up', ArrowDown: 'down', ArrowLeft: 'left', ArrowRight: 'right',
						w: 'up', s: 'down', a: 'left', d: 'right'};
					if (map[e.key]) { e.preventDefault(); tryMove(map[e.key]); }
				});
				document.querySelectorAll('.dpad [data-dir]').forEach((b) => {
					b.addEventListener('click', () => tryMove(b.dataset.dir));
				});
				let touchStart = null;
				canvas.addEventListener('touchstart', (e) => { touchStart = e.touches[0]; }, {passive: true});
				canvas.addEventListener('touchmove', (e) => e.preventDefault(), {passive: false});
				canvas.addEventListener('touchend', (e) => {
					if (!touchStart) return;
					const dx = e.changedTouches[0].clientX - touchStart.clientX;
					const dy = e.changedTouches[0].clientY - touchStart.clientY;
					if (Math.max(Math.abs(dx), Math.abs(dy)) < 18) return;
					if (Math.abs(dx) > Math.abs(dy)) tryMove(dx > 0 ? 'right' : 'left');
					else tryMove(dy > 0 ? 'down' : 'up');
					touchStart = null;
				});

				startBtn.addEventListener('click', () => {
					if (won || !cells) { if (won) level++; newMaze(); }
					overlay.classList.add('hidden');
					cancelAnimationFrame(raf);
					lastT = 0;
					raf = requestAnimationFrame(loop);
				});

				// initial preview behind overlay
				newMaze();
				draw(0);

				// test hook
				window.__maze = {
					walls: () => cells.map((row) => row.map((x) => x.w.slice())),
					pos: () => ({r: cat.r, c: cat.c}),
					goal: () => ({...goal}),
					size: () => N,
					won: () => won,
					move: (d) => tryMove(d),
				};
			})();
		</script>
	</body>
</html>

<style>
	#mazegame { max-width: 560px; margin: 0 auto; }
	.game-hero { padding: 2rem 0 1.4rem; text-align: center; }
	.game-hero h1 { font-size: clamp(1.9rem, 5vw, 2.6rem); margin: 0.5rem 0; }
	.neon { color: var(--accent); text-shadow: 0 0 24px var(--accent-glow); }
	.lead { color: var(--text-muted); font-size: 1.05rem; }

	.hud { display: flex; justify-content: center; gap: 0.7rem; margin-bottom: 0.9rem; }
	.hud-item {
		background: var(--bg-elev); border: 1px solid var(--border); border-radius: 999px;
		padding: 0.4em 1.1em; color: var(--text-muted); font-size: 0.95rem; font-weight: 600;
	}
	.hud-item strong { color: var(--accent); margin-left: 0.35em; }
	.sound-btn { cursor: pointer; font-size: 1rem; line-height: 1; }
	.sound-btn:hover { border-color: var(--accent); }

	.stage { position: relative; }
	#board {
		display: block; width: 100%; height: auto; touch-action: none;
		background: #0b0e14; border: 1px solid var(--border); border-radius: var(--radius);
		box-shadow: 0 0 40px rgba(255, 209, 102, 0.08);
	}
	.overlay {
		position: absolute; inset: 0; display: flex; flex-direction: column;
		align-items: center; justify-content: center; gap: 0.5rem;
		background: rgba(11, 14, 20, 0.85); backdrop-filter: blur(4px);
		border-radius: var(--radius); text-align: center; padding: 1rem;
	}
	.overlay.hidden { display: none; }
	.ov-emoji { font-size: 3.4rem; line-height: 1; }
	.overlay h2 { margin: 0; font-size: 1.7rem; }
	.overlay p { margin: 0 0 0.4rem; color: var(--text-muted); font-size: 1.05rem; }
	.big-btn { font-size: 1.2rem; padding: 0.7em 2em; }

	.dpad { margin: 1.1rem auto 0; width: max-content; }
	.dpad button {
		width: 76px; height: 62px; margin: 4px; border-radius: 18px;
		background: var(--bg-elev); border: 2px solid var(--border);
		font-size: 1.6rem; cursor: pointer;
		transition: transform 0.08s ease, border-color 0.15s ease;
	}
	.dpad button:hover { border-color: var(--accent); }
	.dpad button:active { transform: scale(0.92); background: rgba(62, 245, 139, 0.14); }
	.dpad-mid { display: flex; justify-content: center; }
	.dpad > button { display: block; margin-inline: auto; }

	.howto { margin: 2.2rem 0 3rem; }
	.howto h2 { font-size: 1.25rem; margin: 1.4rem 0 0.6rem; }
	.howto ul { color: var(--text-muted); padding-left: 1.2em; }
	.howto li { margin-bottom: 0.35em; }
</style>
