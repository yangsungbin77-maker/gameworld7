---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = '네온 히어로 — 방치형 용사 키우기 | 게임월드7';
const description =
	'클릭으로 몬스터를 잡고, 용병을 고용해 자동 사냥! 게임을 꺼도 골드가 쌓이는 방치형 키우기 게임. 환생 시스템으로 무한 성장. 무료 · 설치 없음 · 자동 저장.';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div id="herogame">
				<section class="game-hero">
					<span class="tag">PLAY · 방치형</span>
					<h1>⚔️ <span class="neon">네온 히어로</span></h1>
					<p class="lead">
						몬스터를 <strong>클릭</strong>해 처치하고 골드로 용병을 고용하세요. 용병은
						<strong>자동으로 사냥</strong>하고, 게임을 꺼도 골드가 쌓입니다!
					</p>
				</section>

				<div class="hud">
					<div class="hud-item">스테이지 <strong id="stage">1</strong></div>
					<div class="hud-item">💰 <strong id="gold">0</strong></div>
					<div class="hud-item">DPS <strong id="dps">0</strong></div>
					<div class="hud-item">클릭 <strong id="clickDmg">1</strong></div>
					<div class="hud-item relic" id="relicBox" style="display:none">🔮 유물 <strong id="relics">0</strong></div>
				</div>

				<div class="arena">
					<div class="monster-zone">
						<div id="monsterName" class="monster-name">슬라임</div>
						<button id="monster" class="monster" aria-label="몬스터 공격">🟢</button>
						<div class="hpbar"><div id="hpfill" class="hpfill"></div></div>
						<div id="hptext" class="hptext"></div>
					</div>

					<div class="shop">
						<button id="upClick" class="shop-item">
							<span class="s-emoji">🗡️</span>
							<span class="s-info"><strong>검 강화</strong> <em id="upClickLv">Lv.1</em><br /><small id="upClickDesc">클릭 피해 +1</small></span>
							<span class="s-cost" id="upClickCost">10</span>
						</button>
						<div id="heroList"></div>
						<button id="prestige" class="shop-item prestige" style="display:none">
							<span class="s-emoji">🔮</span>
							<span class="s-info"><strong>환생</strong><br /><small id="prestigeDesc"></small></span>
							<span class="s-cost">RESET</span>
						</button>
					</div>
				</div>

				<section class="doc">
					<h2>게임 방법</h2>
					<ul>
						<li>몬스터를 클릭하면 피해를 입힙니다. 처치하면 골드를 얻고 다음 스테이지로 넘어갑니다.</li>
						<li>골드로 <strong>검 강화</strong>(클릭 피해)와 <strong>용병 고용·레벨업</strong>(자동 DPS)을 하세요.</li>
						<li>10스테이지마다 <strong>보스</strong>가 등장합니다. 체력이 높은 대신 골드를 듬뿍 줍니다.</li>
						<li>게임을 꺼도 용병들이 사냥을 계속해 <strong>최대 8시간</strong>까지 골드가 쌓입니다.</li>
						<li>스테이지 30 이후 <strong>환생</strong>이 열립니다. 처음부터 다시 시작하는 대신 유물 1개당 <strong>공격력 +25%</strong> 영구 보너스를 받습니다.</li>
					</ul>
					<h2>자주 묻는 질문</h2>
					<details>
						<summary>진행 상황이 저장되나요?</summary>
						<p>네, 브라우저에 5초마다 자동 저장됩니다. 같은 브라우저로 접속하면 이어서 플레이할 수 있습니다.</p>
					</details>
					<details>
						<summary>방치 보상은 어떻게 계산되나요?</summary>
						<p>접속하지 않은 시간 동안 용병 DPS의 50% 효율로 골드가 쌓입니다. 최대 8시간까지 인정됩니다.</p>
					</details>
					<details>
						<summary>환생은 언제 하는 게 좋나요?</summary>
						<p>스테이지가 잘 안 뚫리기 시작할 때가 타이밍입니다. 환생 유물의 영구 보너스로 다음 회차는 훨씬 빠르게 진행됩니다.</p>
					</details>
				</section>
			</div>
		</main>
		<Footer />

		<div id="offlineModal" class="modal" style="display:none">
			<div class="modal-box">
				<h3>💤 자리 비운 동안…</h3>
				<p>용병들이 <strong id="offlineGold">0</strong> 골드를 모아뒀습니다!</p>
				<button id="offlineOk">받기</button>
			</div>
		</div>

		<script>
			const $ = (id) => document.getElementById(id);
			const KEY = 'gw7-hero-save-v1';

			const MONSTERS = [
				['슬라임', '🟢'], ['박쥐', '🦇'], ['해골', '💀'], ['고블린', '👺'], ['유령', '👻'],
				['늑대', '🐺'], ['골렘', '🗿'], ['마법사', '🧙'], ['악마', '😈'], ['드래곤', '🐉'],
			];
			const HEROES = [
				{ name: '견습 기사', emoji: '🛡️', baseCost: 25, baseDps: 1 },
				{ name: '엘프 궁수', emoji: '🏹', baseCost: 250, baseDps: 6 },
				{ name: '화염 마법사', emoji: '🔥', baseCost: 2500, baseDps: 35 },
				{ name: '성기사', emoji: '⚜️', baseCost: 30000, baseDps: 220 },
				{ name: '드래곤 나이트', emoji: '🐲', baseCost: 400000, baseDps: 1500 },
			];

			let S = {
				stage: 1, gold: 0, clickLv: 1, heroes: [0, 0, 0, 0, 0],
				relics: 0, hp: 0, maxHp: 0, last: Date.now(),
			};

			const fmt = (n) => {
				if (n < 1000) return Math.floor(n).toString();
				const units = ['K', 'M', 'B', 'T', 'Q'];
				let u = -1;
				while (n >= 1000 && u < units.length - 1) { n /= 1000; u++; }
				return n.toFixed(n < 100 ? 1 : 0) + units[u];
			};

			const isBoss = () => S.stage % 10 === 0;
			const monsterHp = () => Math.floor(12 * Math.pow(1.42, S.stage - 1) * (isBoss() ? 6 : 1));
			const goldDrop = () => Math.floor(6 * Math.pow(1.22, S.stage - 1) * (isBoss() ? 5 : 1));
			const dmgMult = () => 1 + S.relics * 0.25;
			const clickDmg = () => Math.floor(Math.pow(1.6, S.clickLv - 1) * 1 * dmgMult());
			const clickCost = () => Math.floor(10 * Math.pow(1.5, S.clickLv - 1));
			const heroDps = (i) => HEROES[i].baseDps * S.heroes[i] * dmgMult();
			const heroCost = (i) => Math.floor(HEROES[i].baseCost * Math.pow(1.16, S.heroes[i]));
			const totalDps = () => HEROES.reduce((a, _, i) => a + heroDps(i), 0);
			const relicGain = () => Math.max(Math.floor(S.stage / 10) - 1, 0);

			function spawn() {
				S.maxHp = monsterHp();
				S.hp = S.maxHp;
				const m = MONSTERS[(S.stage - 1) % MONSTERS.length];
				$('monsterName').textContent = (isBoss() ? '👑 보스 ' : '') + m[0] + ' (스테이지 ' + S.stage + ')';
				$('monster').textContent = m[1];
				$('monster').classList.toggle('boss', isBoss());
			}

			function kill() {
				S.gold += goldDrop();
				S.stage++;
				spawn();
			}

			function hit(dmg) {
				S.hp -= dmg;
				if (S.hp <= 0) kill();
			}

			function render() {
				$('stage').textContent = S.stage;
				$('gold').textContent = fmt(S.gold);
				$('dps').textContent = fmt(totalDps());
				$('clickDmg').textContent = fmt(clickDmg());
				$('hpfill').style.width = Math.max((S.hp / S.maxHp) * 100, 0) + '%';
				$('hptext').textContent = fmt(Math.max(S.hp, 0)) + ' / ' + fmt(S.maxHp);
				$('upClickLv').textContent = 'Lv.' + S.clickLv;
				$('upClickCost').textContent = fmt(clickCost());
				$('upClickDesc').textContent = '클릭 피해 ' + fmt(clickDmg()) + ' → ' + fmt(Math.floor(Math.pow(1.6, S.clickLv) * dmgMult()));
				$('upClick').disabled = S.gold < clickCost();
				HEROES.forEach((h, i) => {
					const btn = $('hero' + i);
					btn.querySelector('.h-lv').textContent = S.heroes[i] ? 'Lv.' + S.heroes[i] : '미고용';
					btn.querySelector('.h-dps').textContent = S.heroes[i] ? 'DPS ' + fmt(heroDps(i)) : 'DPS ' + fmt(h.baseDps * dmgMult()) + '부터';
					btn.querySelector('.s-cost').textContent = fmt(heroCost(i));
					btn.disabled = S.gold < heroCost(i);
				});
				if (S.relics > 0) { $('relicBox').style.display = ''; $('relics').textContent = S.relics + ' (+' + S.relics * 25 + '%)'; }
				if (S.stage >= 30 || S.relics > 0) {
					$('prestige').style.display = '';
					$('prestigeDesc').textContent = '유물 +' + relicGain() + '개 획득 (개당 공격력 +25%)';
					$('prestige').disabled = relicGain() <= 0;
				}
			}

			function save() { S.last = Date.now(); localStorage.setItem(KEY, JSON.stringify(S)); }

			function load() {
				try {
					const d = JSON.parse(localStorage.getItem(KEY));
					if (d && d.stage) {
						S = Object.assign(S, d);
						const away = Math.min((Date.now() - S.last) / 1000, 8 * 3600);
						const earned = Math.floor(totalDps() * away * 0.5);
						if (earned > 100) {
							S.gold += earned;
							$('offlineGold').textContent = fmt(earned);
							$('offlineModal').style.display = 'flex';
						}
					}
				} catch {}
			}

			// UI 구성
			const list = $('heroList');
			HEROES.forEach((h, i) => {
				const b = document.createElement('button');
				b.className = 'shop-item';
				b.id = 'hero' + i;
				b.innerHTML =
					'<span class="s-emoji">' + h.emoji + '</span>' +
					'<span class="s-info"><strong>' + h.name + '</strong> <em class="h-lv"></em><br/><small class="h-dps"></small></span>' +
					'<span class="s-cost"></span>';
				b.addEventListener('click', () => {
					if (S.gold >= heroCost(i)) { S.gold -= heroCost(i); S.heroes[i]++; render(); }
				});
				list.appendChild(b);
			});

			$('monster').addEventListener('click', () => {
				hit(clickDmg());
				const m = $('monster');
				m.classList.remove('shake');
				void m.offsetWidth;
				m.classList.add('shake');
				render();
			});
			$('upClick').addEventListener('click', () => {
				if (S.gold >= clickCost()) { S.gold -= clickCost(); S.clickLv++; render(); }
			});
			$('prestige').addEventListener('click', () => {
				const gain = relicGain();
				if (gain <= 0) return;
				if (!confirm('환생하면 스테이지·골드·용병이 초기화되고 유물 ' + gain + '개를 얻습니다. 진행할까요?')) return;
				S = { stage: 1, gold: 0, clickLv: 1, heroes: [0, 0, 0, 0, 0], relics: S.relics + gain, hp: 0, maxHp: 0, last: Date.now() };
				spawn(); render(); save();
			});
			$('offlineOk').addEventListener('click', () => { $('offlineModal').style.display = 'none'; });

			// 게임 루프
			load();
			spawn();
			render();
			setInterval(() => { if (totalDps() > 0) { hit(totalDps() / 10); render(); } }, 100);
			setInterval(save, 5000);
			window.addEventListener('beforeunload', save);
		</script>

		<style>
			#herogame { max-width: 860px; margin: 0 auto; padding: 8px 12px 40px; }
			.game-hero { text-align: center; margin: 18px 0 14px; }
			.game-hero .tag { font-size: 0.8rem; letter-spacing: 2px; color: #7ef9ff; }
			.game-hero h1 { margin: 6px 0; }
			.neon { color: #7ef9ff; text-shadow: 0 0 12px rgba(126, 249, 255, 0.6); }
			.lead { color: #aab; }
			.hud { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 14px; }
			.hud-item { background: #14162a; border: 1px solid #2a2d4a; border-radius: 10px; padding: 8px 14px; font-size: 0.9rem; color: #ccd; }
			.hud-item strong { color: #ffd76a; }
			.hud-item.relic strong { color: #d98cff; }
			.arena { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
			@media (max-width: 700px) { .arena { grid-template-columns: 1fr; } }
			.monster-zone { background: #14162a; border: 1px solid #2a2d4a; border-radius: 14px; padding: 22px; text-align: center; }
			.monster-name { color: #eef; font-weight: 700; margin-bottom: 10px; }
			.monster { font-size: 6rem; background: none; border: none; cursor: pointer; transition: transform 0.05s; line-height: 1.2; }
			.monster.boss { font-size: 7.5rem; filter: drop-shadow(0 0 14px rgba(255, 80, 80, 0.7)); }
			.monster:active { transform: scale(0.92); }
			.monster.shake { animation: shake 0.15s; }
			@keyframes shake { 25% { transform: translateX(-4px); } 75% { transform: translateX(4px); } }
			.hpbar { height: 14px; background: #23253f; border-radius: 7px; overflow: hidden; margin-top: 12px; }
			.hpfill { height: 100%; width: 100%; background: linear-gradient(90deg, #ff5d5d, #ffb35d); transition: width 0.1s; }
			.hptext { color: #99a; font-size: 0.85rem; margin-top: 6px; }
			.shop { display: flex; flex-direction: column; gap: 8px; }
			.shop-item { display: flex; align-items: center; gap: 12px; width: 100%; text-align: left; background: #14162a; border: 1px solid #2a2d4a; border-radius: 12px; padding: 10px 14px; cursor: pointer; color: #dde; transition: border-color 0.15s; }
			.shop-item:hover:not(:disabled) { border-color: #7ef9ff; }
			.shop-item:disabled { opacity: 0.45; cursor: default; }
			.shop-item .s-emoji { font-size: 1.7rem; }
			.shop-item .s-info { flex: 1; font-size: 0.9rem; }
			.shop-item .s-info em { color: #7ef9ff; font-style: normal; font-size: 0.8rem; }
			.shop-item .s-info small { color: #99a; }
			.shop-item .s-cost { color: #ffd76a; font-weight: 700; }
			.shop-item.prestige { border-color: #6a3d99; }
			.shop-item.prestige:hover:not(:disabled) { border-color: #d98cff; }
			.doc { margin-top: 34px; color: #bbc; }
			.doc h2 { color: #eef; font-size: 1.15rem; margin: 22px 0 8px; }
			.doc li { margin-bottom: 6px; font-size: 0.93rem; }
			.doc details { background: #14162a; border: 1px solid #2a2d4a; border-radius: 10px; padding: 10px 14px; margin-bottom: 8px; }
			.doc summary { cursor: pointer; font-weight: 600; color: #dde; }
			.doc details p { margin: 8px 0 2px; font-size: 0.9rem; }
			.modal { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.65); display: flex; align-items: center; justify-content: center; z-index: 50; }
			.modal-box { background: #1a1d35; border: 1px solid #7ef9ff; border-radius: 14px; padding: 26px 32px; text-align: center; color: #eef; }
			.modal-box strong { color: #ffd76a; }
			.modal-box button { margin-top: 14px; background: #7ef9ff; color: #10122a; border: none; border-radius: 8px; padding: 10px 26px; font-weight: 700; cursor: pointer; }
		</style>
	</body>
</html>
