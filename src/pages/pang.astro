---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = '네온 팡 (Neon Pang) — 60초 매치3 퍼즐 | 게임월드7';
const description =
	'애니팡처럼 같은 보석 3개를 맞춰 터뜨리는 60초 타임어택 매치3 퍼즐. 연쇄 콤보로 점수를 불리고 최고 기록에 도전하세요! 무료 · 설치 없음.';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div id="panggame">
				<section class="game-hero">
					<span class="tag">PLAY · 미니게임</span>
					<h1>💎 <span class="neon">네온 팡</span></h1>
					<p class="lead">같은 네온 보석을 <strong>3개 이상</strong> 맞춰 터뜨리세요. 제한시간 60초, 연쇄 콤보가 점수를 불립니다!</p>
				</section>

				<div class="hud">
					<div class="hud-item">점수 <strong id="score">0</strong></div>
					<div class="hud-item">최고 기록 <strong id="best">0</strong></div>
					<div class="hud-item">남은 시간 <strong id="time">60</strong></div>
					<button class="hud-item sound-btn" id="soundBtn" type="button" aria-label="효과음 켜기/끄기">🔊</button>
				</div>
				<div class="timebar"><div class="timebar-fill" id="timebar"></div></div>

				<div class="stage">
					<canvas id="board" width="480" height="480" aria-label="네온 팡 퍼즐 보드"></canvas>
					<div class="overlay" id="overlay">
						<h2 id="ov-title">네온 팡</h2>
						<p id="ov-sub">보석을 밀어서 3개를 맞추세요 · 60초</p>
						<button class="btn" id="startBtn" type="button">게임 시작</button>
						<button class="btn-ghost btn" id="shareBtn" type="button" hidden>점수 공유</button>
					</div>
				</div>

				<section class="howto">
					<h2>조작법</h2>
					<ul>
						<li>보석을 <strong>클릭(터치)한 뒤 옆 보석을 클릭</strong>하거나, 원하는 방향으로 <strong>밀면(드래그)</strong> 자리가 바뀝니다.</li>
						<li>가로·세로로 같은 보석이 3개 이상 이어지면 터집니다. 자리를 바꿔도 터지지 않는 이동은 원위치됩니다.</li>
						<li>터진 자리로 위 보석이 떨어지며 <strong>연쇄가 나면 콤보 배수</strong>가 붙습니다(2연쇄 ×2, 3연쇄 ×3…).</li>
						<li>움직일 수 있는 곳이 없으면 보드가 자동으로 섞입니다.</li>
						<li>상단 🔊 버튼으로 효과음을 켜고 끌 수 있습니다.</li>
					</ul>
					<h2>고득점 팁</h2>
					<ul>
						<li><strong>아래쪽부터 터뜨리세요.</strong> 위가 무너져 내려오면서 연쇄가 훨씬 잘 납니다.</li>
						<li>4~5개짜리 줄을 만들 수 있으면 3개짜리보다 한 번에 점수가 큽니다.</li>
						<li>망설이는 시간이 최대의 적입니다. 완벽한 수보다 빠른 손이 이깁니다.</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const canvas = document.getElementById('board');
				const ctx = canvas.getContext('2d');
				const N = 8;
				const CELL = canvas.width / N;
				const scoreEl = document.getElementById('score');
				const bestEl = document.getElementById('best');
				const timeEl = document.getElementById('time');
				const timebar = document.getElementById('timebar');
				const overlay = document.getElementById('overlay');
				const ovTitle = document.getElementById('ov-title');
				const ovSub = document.getElementById('ov-sub');
				const startBtn = document.getElementById('startBtn');
				const shareBtn = document.getElementById('shareBtn');
				const BEST_KEY = 'gw7_pang_best';
				const GAME_SEC = 60;

				const GEMS = [
					{color: '#3ef58b', shape: 'circle'},
					{color: '#00e5ff', shape: 'triangle'},
					{color: '#ff2fb3', shape: 'diamond'},
					{color: '#ffd166', shape: 'star'},
					{color: '#b78bff', shape: 'hex'},
					{color: '#ff7a5c', shape: 'square'},
				];

				let grid; // grid[r][c] = {t, py, scale} | null during collapse
				let state = 'off'; // off | idle | swap | clear | fall
				let score, best, combo, comboFlash;
				let timeLeft, timerId, raf;
				let selected = null;
				let swapAnim = null; // {a,b,t0,dur,revert}
				let clearT0 = 0, clearing = [];
				let pointerDown = null;

				best = Number(localStorage.getItem(BEST_KEY) || 0);
				bestEl.textContent = best;

				// --- sound (Web Audio 합성, 외부 파일 없음) ---
				const soundBtn = document.getElementById('soundBtn');
				const SOUND_KEY = 'gw7_pang_sound';
				let soundOn = localStorage.getItem(SOUND_KEY) !== '0';
				let audioCtx = null;
				const updateSoundBtn = () => { soundBtn.textContent = soundOn ? '🔊' : '🔇'; };
				updateSoundBtn();
				soundBtn.addEventListener('click', () => {
					soundOn = !soundOn;
					localStorage.setItem(SOUND_KEY, soundOn ? '1' : '0');
					updateSoundBtn();
					if (soundOn) tone(520, 0.08, 'sine', 0.15, 0, 160);
				});
				function ac() {
					if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
					if (audioCtx.state === 'suspended') audioCtx.resume();
					return audioCtx;
				}
				function tone(freq, dur, type, vol, when, slide) {
					if (!soundOn) return;
					try {
						const a = ac();
						const t0 = a.currentTime + (when || 0);
						const o = a.createOscillator();
						const g = a.createGain();
						o.type = type || 'sine';
						o.frequency.setValueAtTime(freq, t0);
						if (slide) o.frequency.exponentialRampToValueAtTime(Math.max(40, freq + slide), t0 + dur);
						g.gain.setValueAtTime(vol || 0.2, t0);
						g.gain.exponentialRampToValueAtTime(0.001, t0 + dur);
						o.connect(g).connect(a.destination);
						o.start(t0);
						o.stop(t0 + dur + 0.02);
					} catch {}
				}
				const sndSwap = () => tone(320, 0.08, 'sine', 0.1, 0, 240);
				const sndInvalid = () => tone(150, 0.12, 'square', 0.07, 0, -60);
				const sndPop = (cb, count) => {
					const base = 440 + Math.min(6, cb) * 70;
					tone(base, 0.12, 'triangle', 0.2, 0, 220);
					tone(base * 1.5, 0.1, 'sine', 0.11, 0.02, 180);
					if (count >= 4) tone(base * 2, 0.14, 'sine', 0.1, 0.05, 120);
				};
				const sndCombo = (cb) => [0, 0.07, 0.14].forEach((d, i) => tone(520 + cb * 60 + i * 130, 0.09, 'triangle', 0.15, d, 60));
				const sndTimeUp = () => { tone(440, 0.18, 'sawtooth', 0.13, 0, -180); tone(330, 0.25, 'sawtooth', 0.1, 0.15, -140); };

				// --- impact FX ---
				let particles = [];
				let rings = [];
				let shakeAmp = 0;
				function burst(x, y, color, power) {
					const n = 10 + Math.min(14, power * 2);
					for (let i = 0; i < n; i++) {
						const a = Math.random() * Math.PI * 2;
						const sp = (1.5 + Math.random() * 3.5) * (1 + power * 0.12);
						particles.push({x, y, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp - 1.4, life: 1, color, r: 2 + Math.random() * 3});
					}
					rings.push({x, y, r: CELL * 0.2, color, life: 1});
				}

				const inBounds = (r, c) => r >= 0 && c >= 0 && r < N && c < N;
				const randType = () => Math.floor(Math.random() * GEMS.length);

				function makeGem(t) { return {t, py: 0, scale: 1}; }

				function typeAt(g, r, c) { return g[r][c] ? g[r][c].t : -1; }

				function findMatchesIn(g) {
					const hit = new Set();
					for (let r = 0; r < N; r++) {
						let run = 1;
						for (let c = 1; c <= N; c++) {
							if (c < N && typeAt(g, r, c) !== -1 && typeAt(g, r, c) === typeAt(g, r, c - 1)) run++;
							else {
								if (run >= 3) for (let k = c - run; k < c; k++) hit.add(r * N + k);
								run = 1;
							}
						}
					}
					for (let c = 0; c < N; c++) {
						let run = 1;
						for (let r = 1; r <= N; r++) {
							if (r < N && typeAt(g, r, c) !== -1 && typeAt(g, r, c) === typeAt(g, r - 1, c)) run++;
							else {
								if (run >= 3) for (let k = r - run; k < r; k++) hit.add(k * N + c);
								run = 1;
							}
						}
					}
					return hit;
				}

				function hasMove(g) {
					const t = g.map((row) => row.map((x) => x.t));
					const tryswap = (r1, c1, r2, c2) => {
						[t[r1][c1], t[r2][c2]] = [t[r2][c2], t[r1][c1]];
						const wrap = t.map((row) => row.map((x) => ({t: x})));
						const ok = findMatchesIn(wrap).size > 0;
						[t[r1][c1], t[r2][c2]] = [t[r2][c2], t[r1][c1]];
						return ok;
					};
					for (let r = 0; r < N; r++)
						for (let c = 0; c < N; c++) {
							if (c + 1 < N && tryswap(r, c, r, c + 1)) return true;
							if (r + 1 < N && tryswap(r, c, r + 1, c)) return true;
						}
					return false;
				}

				function buildBoard() {
					grid = [];
					for (let r = 0; r < N; r++) {
						grid.push([]);
						for (let c = 0; c < N; c++) {
							let t;
							do { t = randType(); grid[r][c] = makeGem(t); }
							while (
								(c >= 2 && grid[r][c - 1].t === t && grid[r][c - 2].t === t) ||
								(r >= 2 && grid[r - 1][c].t === t && grid[r - 2][c].t === t)
							);
						}
					}
					if (!hasMove(grid)) buildBoard();
				}

				function reshuffle() {
					const types = [];
					grid.forEach((row) => row.forEach((g) => types.push(g.t)));
					do {
						for (let i = types.length - 1; i > 0; i--) {
							const j = Math.floor(Math.random() * (i + 1));
							[types[i], types[j]] = [types[j], types[i]];
						}
						let i = 0;
						grid.forEach((row) => row.forEach((g) => (g.t = types[i++])));
					} while (findMatchesIn(grid).size > 0 || !hasMove(grid));
				}

				// --- game flow ---
				function startGame() {
					buildBoard();
					score = 0; combo = 0; comboFlash = null;
					scoreEl.textContent = '0';
					timeLeft = GAME_SEC;
					timeEl.textContent = GAME_SEC;
					timebar.style.width = '100%';
					selected = null;
					particles = [];
					rings = [];
					shakeAmp = 0;
					state = 'idle';
					overlay.classList.add('hidden');
					clearInterval(timerId);
					timerId = setInterval(() => {
						timeLeft--;
						timeEl.textContent = Math.max(0, timeLeft);
						timebar.style.width = (Math.max(0, timeLeft) / GAME_SEC) * 100 + '%';
						if (timeLeft <= 0) endGame();
					}, 1000);
					cancelAnimationFrame(raf);
					raf = requestAnimationFrame(loop);
				}

				function endGame() {
					clearInterval(timerId);
					state = 'off';
					sndTimeUp();
					if (score > best) {
						best = score;
						localStorage.setItem(BEST_KEY, best);
						bestEl.textContent = best;
					}
					ovTitle.textContent = '타임 업!';
					ovSub.textContent = `점수 ${score} · 최고 기록 ${best}`;
					startBtn.textContent = '다시 하기';
					shareBtn.hidden = false;
					overlay.classList.remove('hidden');
				}

				function trySwap(a, b) {
					if (state !== 'idle') return;
					if (Math.abs(a.r - b.r) + Math.abs(a.c - b.c) !== 1) return;
					selected = null;
					state = 'swap';
					sndSwap();
					swapAnim = {a, b, t0: performance.now(), dur: 120, revert: false};
				}

				function commitSwap() {
					const {a, b} = swapAnim;
					[grid[a.r][a.c], grid[b.r][b.c]] = [grid[b.r][b.c], grid[a.r][a.c]];
					if (!swapAnim.revert) {
						const matches = findMatchesIn(grid);
						if (matches.size > 0) {
							swapAnim = null;
							combo = 0;
							startClear(matches);
							return;
						}
						sndInvalid();
						swapAnim = {a, b, t0: performance.now(), dur: 120, revert: true};
					} else {
						swapAnim = null;
						state = 'idle';
					}
				}

				function startClear(matches) {
					state = 'clear';
					combo++;
					clearT0 = performance.now();
					clearing = [...matches];
					const gained = 10 * clearing.length * combo;
					score += gained;
					scoreEl.textContent = score;
					if (combo >= 2) comboFlash = {text: `콤보 ×${combo}!`, t0: performance.now()};
					sndPop(combo, clearing.length);
					if (combo >= 2) sndCombo(combo);
					shakeAmp = Math.min(11, 2 + clearing.length * 0.6 + combo * 1.6);
					clearing.forEach((idx) => {
						const r = Math.floor(idx / N), c = idx % N;
						const g = grid[r][c];
						if (g) {
							g.clearing = true;
							burst((c + 0.5) * CELL, (r + 0.5) * CELL + g.py, GEMS[g.t].color, clearing.length + combo);
						}
					});
				}

				function collapse() {
					clearing.forEach((idx) => { grid[Math.floor(idx / N)][idx % N] = null; });
					clearing = [];
					for (let c = 0; c < N; c++) {
						let write = N - 1;
						for (let r = N - 1; r >= 0; r--) {
							if (grid[r][c]) {
								if (write !== r) {
									grid[write][c] = grid[r][c];
									grid[write][c].py = (r - write) * CELL;
									grid[r][c] = null;
								}
								write--;
							}
						}
						let spawn = 1;
						for (let r = write; r >= 0; r--) {
							grid[r][c] = makeGem(randType());
							grid[r][c].py = -(spawn++) * CELL - CELL * 0.4;
						}
					}
					state = 'fall';
				}

				function updateFall(dt) {
					let moving = false;
					const v = CELL * dt * 0.022;
					grid.forEach((row) => row.forEach((g) => {
						if (!g) return;
						if (g.py < 0) { g.py = Math.min(0, g.py + v); moving = moving || g.py < 0; }
						else if (g.py > 0) { g.py = Math.max(0, g.py - v); moving = moving || g.py > 0; }
					}));
					if (!moving) {
						const matches = findMatchesIn(grid);
						if (matches.size > 0) startClear(matches);
						else {
							state = 'idle';
							if (!hasMove(grid)) reshuffle();
						}
					}
				}

				// --- rendering ---
				function drawGem(x, y, t, scale, glow) {
					const g = GEMS[t];
					const s = CELL * 0.36 * scale;
					ctx.save();
					ctx.translate(x, y);
					ctx.shadowColor = g.color;
					ctx.shadowBlur = glow ? 22 : 12;
					ctx.fillStyle = g.color;
					ctx.beginPath();
					if (g.shape === 'circle') ctx.arc(0, 0, s, 0, Math.PI * 2);
					else if (g.shape === 'square') { const k = s * 0.9; ctx.roundRect(-k, -k, k * 2, k * 2, 6); }
					else if (g.shape === 'diamond') { ctx.moveTo(0, -s * 1.1); ctx.lineTo(s * 0.85, 0); ctx.lineTo(0, s * 1.1); ctx.lineTo(-s * 0.85, 0); }
					else if (g.shape === 'triangle') { ctx.moveTo(0, -s); ctx.lineTo(s, s * 0.75); ctx.lineTo(-s, s * 0.75); }
					else if (g.shape === 'hex') for (let i = 0; i < 6; i++) { const a = Math.PI / 3 * i - Math.PI / 6; ctx[i ? 'lineTo' : 'moveTo'](s * Math.cos(a), s * Math.sin(a)); }
					else if (g.shape === 'star') for (let i = 0; i < 10; i++) { const rr = i % 2 ? s * 0.45 : s; const a = Math.PI / 5 * i - Math.PI / 2; ctx[i ? 'lineTo' : 'moveTo'](rr * Math.cos(a), rr * Math.sin(a)); }
					ctx.closePath();
					ctx.fill();
					ctx.restore();
				}

				let lastT = 0;
				function loop(t) {
					const dt = lastT ? Math.min(50, t - lastT) : 16;
					lastT = t;

					if (state === 'swap' && swapAnim) {
						if (t - swapAnim.t0 >= swapAnim.dur) commitSwap();
					} else if (state === 'clear') {
						if (t - clearT0 >= 150) collapse();
					} else if (state === 'fall') {
						updateFall(dt);
					}

					// draw
					ctx.fillStyle = '#0b0e14';
					ctx.fillRect(0, 0, canvas.width, canvas.height);
					ctx.save();
					if (shakeAmp > 0.3) {
						ctx.translate((Math.random() * 2 - 1) * shakeAmp, (Math.random() * 2 - 1) * shakeAmp);
						shakeAmp *= Math.pow(0.88, dt / 16);
					} else shakeAmp = 0;
					ctx.strokeStyle = 'rgba(62,245,139,0.05)';
					for (let i = 1; i < N; i++) {
						ctx.beginPath(); ctx.moveTo(i * CELL, 0); ctx.lineTo(i * CELL, canvas.height); ctx.stroke();
						ctx.beginPath(); ctx.moveTo(0, i * CELL); ctx.lineTo(canvas.width, i * CELL); ctx.stroke();
					}

					for (let r = 0; r < N; r++)
						for (let c = 0; c < N; c++) {
							const g = grid && grid[r][c];
							if (!g) continue;
							let x = (c + 0.5) * CELL, y = (r + 0.5) * CELL + g.py;
							let scale = 1;
							if (g.clearing) scale = Math.max(0, 1 - (t - clearT0) / 150);
							if (swapAnim) {
								const {a, b, t0, dur} = swapAnim;
								const k = Math.min(1, (t - t0) / dur);
								if (a.r === r && a.c === c) { x += (b.c - a.c) * CELL * k; y += (b.r - a.r) * CELL * k; }
								if (b.r === r && b.c === c) { x += (a.c - b.c) * CELL * k; y += (a.r - b.r) * CELL * k; }
							}
							const sel = selected && selected.r === r && selected.c === c;
							if (sel) {
								ctx.save();
								ctx.strokeStyle = '#fff';
								ctx.shadowColor = '#fff'; ctx.shadowBlur = 12;
								ctx.lineWidth = 2;
								ctx.strokeRect(c * CELL + 4, r * CELL + 4, CELL - 8, CELL - 8);
								ctx.restore();
							}
							if (scale > 0) drawGem(x, y, g.t, scale, sel);
						}

					// rings + particles (터지는 임팩트)
					for (let i = rings.length - 1; i >= 0; i--) {
						const rg = rings[i];
						rg.r += dt * 0.32;
						rg.life -= dt / 320;
						if (rg.life <= 0) { rings.splice(i, 1); continue; }
						ctx.save();
						ctx.globalAlpha = rg.life * 0.8;
						ctx.strokeStyle = rg.color;
						ctx.shadowColor = rg.color;
						ctx.shadowBlur = 14;
						ctx.lineWidth = 2.5;
						ctx.beginPath();
						ctx.arc(rg.x, rg.y, rg.r, 0, Math.PI * 2);
						ctx.stroke();
						ctx.restore();
					}
					for (let i = particles.length - 1; i >= 0; i--) {
						const p = particles[i];
						p.x += p.vx * (dt / 16);
						p.y += p.vy * (dt / 16);
						p.vy += 0.09 * (dt / 16);
						p.life -= dt / 650;
						if (p.life <= 0) { particles.splice(i, 1); continue; }
						ctx.save();
						ctx.globalAlpha = Math.max(0, p.life);
						ctx.fillStyle = p.color;
						ctx.shadowColor = p.color;
						ctx.shadowBlur = 10;
						ctx.beginPath();
						ctx.arc(p.x, p.y, p.r * p.life, 0, Math.PI * 2);
						ctx.fill();
						ctx.restore();
					}

					if (comboFlash) {
						const k = (t - comboFlash.t0) / 900;
						if (k >= 1) comboFlash = null;
						else {
							ctx.save();
							ctx.globalAlpha = 1 - k;
							ctx.fillStyle = '#ffd166';
							ctx.shadowColor = '#ffd166'; ctx.shadowBlur = 18;
							ctx.font = '800 30px system-ui, sans-serif';
							ctx.textAlign = 'center';
							ctx.fillText(comboFlash.text, canvas.width / 2, canvas.height * 0.32 - k * 26);
							ctx.restore();
						}
					}

					ctx.restore();

					if (state !== 'off') raf = requestAnimationFrame(loop);
				}

				// --- input ---
				function cellFromEvent(e) {
					const rect = canvas.getBoundingClientRect();
					const x = ((e.clientX - rect.left) / rect.width) * canvas.width;
					const y = ((e.clientY - rect.top) / rect.height) * canvas.height;
					const c = Math.floor(x / CELL), r = Math.floor(y / CELL);
					return inBounds(r, c) ? {r, c} : null;
				}

				canvas.addEventListener('pointerdown', (e) => {
					if (state !== 'idle') return;
					const cell = cellFromEvent(e);
					if (!cell) return;
					pointerDown = {cell, x: e.clientX, y: e.clientY};
					if (selected && Math.abs(selected.r - cell.r) + Math.abs(selected.c - cell.c) === 1) {
						trySwap(selected, cell);
						pointerDown = null;
					} else {
						selected = cell;
					}
				});
				canvas.addEventListener('pointermove', (e) => {
					if (!pointerDown || state !== 'idle') return;
					const dx = e.clientX - pointerDown.x, dy = e.clientY - pointerDown.y;
					if (Math.max(Math.abs(dx), Math.abs(dy)) < 22) return;
					const {r, c} = pointerDown.cell;
					const target = Math.abs(dx) > Math.abs(dy)
						? {r, c: c + (dx > 0 ? 1 : -1)}
						: {r: r + (dy > 0 ? 1 : -1), c};
					pointerDown = null;
					if (inBounds(target.r, target.c)) trySwap({r, c}, target);
				});
				canvas.addEventListener('pointerup', () => { pointerDown = null; });

				startBtn.addEventListener('click', startGame);
				shareBtn.addEventListener('click', async () => {
					const text = `네온 팡 60초에 ${score}점! 나를 이겨봐 👉 ${location.href}`;
					try {
						await navigator.clipboard.writeText(text);
						shareBtn.textContent = '복사 완료!';
					} catch {
						shareBtn.textContent = text;
					}
					setTimeout(() => (shareBtn.textContent = '점수 공유'), 1600);
				});

				// static preview board behind overlay
				buildBoard();
				(function previewDraw() {
					ctx.fillStyle = '#0b0e14';
					ctx.fillRect(0, 0, canvas.width, canvas.height);
					for (let r = 0; r < N; r++)
						for (let c = 0; c < N; c++) drawGem((c + 0.5) * CELL, (r + 0.5) * CELL, grid[r][c].t, 1, false);
				})();

				// test hook (no gameplay effect)
				window.__pang = {
					gridTypes: () => grid.map((row) => row.map((g) => (g ? g.t : -1))),
					state: () => state,
					score: () => score,
					swap: (r1, c1, r2, c2) => trySwap({r: r1, c: c1}, {r: r2, c: c2}),
				};
			})();
		</script>
	</body>
</html>

