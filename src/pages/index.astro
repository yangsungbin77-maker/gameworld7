---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { GAMES as games, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts[0];
const rest = posts.slice(1, 7);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<span class="tag">GAME · 공략 · 리뷰</span>
				<h1>게임의 <span class="neon">모든 것</span>,<br />가장 빠르게.</h1>
				<p class="lead">{SITE_DESCRIPTION}</p>
				<div class="hero-actions">
					<a href="/blog" class="btn">최신 글 보기</a>
					<a href="/about" class="btn-ghost btn">소개</a>
				</div>
			</section>

			<section class="games" id="games">
				<div class="section-head">
					<h2>🎮 지금 바로 플레이</h2>
					<a href="/games" class="more">전체 게임 →</a>
				</div>
				<ul class="game-grid">
					{games.map((g) => (
						<li>
							<a href={g.href} class="game-card">
								<div class="game-cover">
									<img src={g.cover} alt={`${g.title} 게임 커버`} loading="lazy" width="640" height="360" />
									<span class="game-title-overlay">{g.emoji} {g.title}</span>
								</div>
								<div class="game-card-foot">
									<div class="game-info">
										<span class="game-genre">{g.genre}</span>
										<p>{g.desc}</p>
									</div>
									<span class="play-btn">Play</span>
								</div>
							</a>
						</li>
					))}
				</ul>
			</section>

			{
				featured && (
					<a href={`/${featured.id}/`} class="featured">
						{featured.data.heroImage && (
							<div class="featured-image">
								<Image src={featured.data.heroImage} width={1200} height={600} alt={featured.data.title} />
							</div>
						)}
						<div class="featured-body">
							<span class="tag">최신 글</span>
							<h2>{featured.data.title}</h2>
							<p>{featured.data.description}</p>
							<span class="meta">
								<FormattedDate date={featured.data.pubDate} /> · 읽어보기 →
							</span>
						</div>
					</a>
				)
			}

			{
				rest.length > 0 && (
					<>
						<div class="section-head">
							<h2>더 많은 글</h2>
							<a href="/blog" class="more">전체 보기 →</a>
						</div>
						<ul class="grid">
							{rest.map((post) => (
								<li>
									<a href={`/${post.id}/`} class="card">
										{post.data.heroImage && (
											<div class="card-image">
												<Image src={post.data.heroImage} width={600} height={300} alt={post.data.title} />
											</div>
										)}
										<div class="card-body">
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
											<span class="meta">
												<FormattedDate date={post.data.pubDate} />
											</span>
										</div>
									</a>
								</li>
							))}
						</ul>
					</>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 2.5rem 0 3rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2.5rem;
	}
	.hero h1 {
		font-size: clamp(2.4rem, 6vw, 4rem);
		margin: 0.6rem 0 0.8rem;
	}
	.neon {
		color: var(--accent);
		text-shadow: 0 0 24px var(--accent-glow);
	}
	.lead {
		color: var(--text-muted);
		font-size: 1.15rem;
		max-width: 38ch;
		margin-bottom: 1.6rem;
	}
	.hero-actions {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.games {
		margin-bottom: 3rem;
	}
	.games-note {
		color: var(--text-dim);
		font-size: 0.88rem;
		font-weight: 600;
	}
	.game-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.2rem;
	}
	.game-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--bg-elev);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		text-decoration: none;
		transition: border-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
	}
	.game-card:hover {
		border-color: var(--accent);
		transform: translateY(-3px);
		box-shadow: 0 14px 40px rgba(0, 0, 0, 0.45), 0 0 24px var(--accent-glow);
	}
	.game-cover {
		position: relative;
	}
	.game-cover img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-bottom: 1px solid var(--border);
	}
	.game-title-overlay {
		position: absolute;
		left: 0.9rem;
		bottom: 0.7rem;
		font-family: var(--font-heading);
		font-weight: 800;
		font-size: 1.35rem;
		color: #fff;
		text-shadow: 0 2px 12px rgba(0, 0, 0, 0.9), 0 0 20px var(--accent-glow);
	}
	.game-card-foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.2rem;
	}
	.game-info p {
		margin: 0.3rem 0 0;
		color: var(--text-muted);
		font-size: 0.9rem;
	}
	.game-genre {
		display: inline-block;
		padding: 0.15em 0.7em;
		border-radius: 999px;
		background: rgba(62, 245, 139, 0.12);
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 700;
	}
	.play-btn {
		flex-shrink: 0;
		padding: 0.5em 1.4em;
		border-radius: 999px;
		background: var(--accent);
		color: #0b0e14;
		font-weight: 800;
		font-size: 0.95rem;
		transition: filter 0.15s ease, transform 0.15s ease;
	}
	.game-card:hover .play-btn {
		filter: brightness(1.15);
		transform: scale(1.05);
	}

	.featured {
		display: block;
		background:
			linear-gradient(180deg, rgba(62, 245, 139, 0.08), transparent 40%),
			var(--bg-elev);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		margin-bottom: 3rem;
		transition: border-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
	}
	.featured:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow: 0 14px 40px rgba(0, 0, 0, 0.4);
	}
	.featured-image img {
		display: block;
		width: 100%;
		aspect-ratio: 2 / 1;
		object-fit: cover;
		border-bottom: 1px solid var(--border);
	}
	.featured-body { padding: 2rem; }
	.featured h2 {
		margin: 0.8rem 0 0.5rem;
		font-size: clamp(1.6rem, 3.5vw, 2.3rem);
	}
	.featured p {
		color: var(--text-muted);
		margin-bottom: 1rem;
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1.4rem;
	}
	.section-head h2 { margin: 0; }
	.more { font-weight: 600; font-size: 0.95rem; }

	.grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.2rem;
	}
	.card {
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--bg-elev);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		transition: border-color 0.2s ease, transform 0.15s ease, background 0.2s ease;
	}
	.card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		background: var(--bg-elev-2);
	}
	.card-image img {
		display: block;
		width: 100%;
		aspect-ratio: 2 / 1;
		object-fit: cover;
		border-bottom: 1px solid var(--border);
	}
	.card-body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: 1.5rem;
	}
	.card h3 {
		margin: 0 0 0.5rem;
		font-size: 1.25rem;
	}
	.card p {
		color: var(--text-muted);
		font-size: 0.95rem;
		margin-bottom: 1rem;
		flex: 1;
	}
	.meta {
		color: var(--text-dim);
		font-size: 0.85rem;
		font-weight: 600;
	}
</style>
