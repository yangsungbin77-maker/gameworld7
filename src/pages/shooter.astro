---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = '네온 스카이 — 비행기 슈팅 게임 (무기 업그레이드) | 게임월드7';
const description =
	'네온 전투기로 적을 격추하고 아이템을 먹어 무기를 5단계까지 업그레이드하는 무료 비행기 슈팅 게임. 자동 발사라 조작은 이동뿐, 모바일 완벽 지원.';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div id="flygame">
				<section class="game-hero">
					<span class="tag">PLAY · 미니게임</span>
					<h1>🛩️ <span class="neon">네온 스카이</span></h1>
					<p class="lead">적을 격추하고 아이템을 먹어 <strong>무기를 5단계까지 업그레이드</strong>하세요. 발사는 자동, 조작은 이동뿐!</p>
				</section>

				<div class="hud">
					<div class="hud-item">점수 <strong id="score">0</strong></div>
					<div class="hud-item">최고 <strong id="best">0</strong></div>
					<div class="hud-item">무기 <strong id="weapon">Lv.1</strong></div>
					<div class="hud-item">생명 <strong id="lives">❤️❤️❤️</strong></div>
					<button class="hud-item tool-btn" id="soundBtn" type="button" aria-label="효과음 켜기/끄기">🔊</button>
				</div>

				<div class="stage">
					<canvas id="board" width="480" height="640" aria-label="네온 스카이 게임 화면"></canvas>
					<div class="overlay" id="overlay">
						<h2 id="ov-title">네온 스카이</h2>
						<p id="ov-sub">드래그·마우스로 기체 이동 · 발사는 자동</p>
						<button class="btn" id="startBtn" type="button">출격!</button>
						<button class="btn-ghost btn" id="shareBtn" type="button" hidden>점수 공유</button>
					</div>
				</div>

				<section class="howto">
					<h2>조작법</h2>
					<ul>
						<li><strong>PC</strong> — 마우스를 움직이면 기체가 따라옵니다. 방향키·WASD도 지원.</li>
						<li><strong>모바일</strong> — 화면을 드래그하면 기체가 손가락을 따라옵니다(손가락 살짝 위에 떠서 가려지지 않아요).</li>
						<li>발사는 <strong>자동</strong>입니다. 피하고, 먹고, 버티세요!</li>
					</ul>
					<h2>아이템</h2>
					<ul>
						<li><strong>🔫 파워(P)</strong> — 무기 레벨 +1. 싱글 → 더블 → 3방향 → 4연장 → 5웨이(최대 Lv.5).</li>
						<li><strong>⚡ 연사(R)</strong> — 발사 속도가 빨라집니다(중첩 가능).</li>
						<li><strong>💖 생명</strong> — 생명 +1 (최대 5). 탱크형 적은 아이템 확정 드랍!</li>
						<li>적탄이나 적과 부딪히면 생명 −1에 <strong>무기도 한 단계 다운</strong>됩니다. 파워를 지키세요!</li>
					</ul>
					<h2>공략 팁</h2>
					<ul>
						<li>초반엔 아이템 회수 최우선. Lv.3만 돼도 화면이 정리되기 시작합니다.</li>
						<li>느린 <strong>탱크형(보라 육각)</strong>은 아이템 확정이라 무조건 잡고, 지그재그형은 궤도 아래에서 기다리세요.</li>
						<li>시간이 갈수록 적이 빨라지고 총을 쏩니다. 화면 아래 구석에 오래 머물지 마세요.</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const canvas = document.getElementById('board');
				const ctx = canvas.getContext('2d');
				const W = canvas.width, H = canvas.height;
				const scoreEl = document.getElementById('score');
				const bestEl = document.getElementById('best');
				const weaponEl = document.getElementById('weapon');
				const livesEl = document.getElementById('lives');
				const overlay = document.getElementById('overlay');
				const ovTitle = document.getElementById('ov-title');
				const ovSub = document.getElementById('ov-sub');
				const startBtn = document.getElementById('startBtn');
				const shareBtn = document.getElementById('shareBtn');
				const BEST_KEY = 'gw7_shooter_best';

				// --- sound ---
				const soundBtn = document.getElementById('soundBtn');
				const SOUND_KEY = 'gw7_shooter_sound';
				let soundOn = localStorage.getItem(SOUND_KEY) !== '0';
				let audioCtx = null;
				const updateSoundBtn = () => { soundBtn.textContent = soundOn ? '🔊' : '🔇'; };
				updateSoundBtn();
				soundBtn.addEventListener('click', () => {
					soundOn = !soundOn;
					localStorage.setItem(SOUND_KEY, soundOn ? '1' : '0');
					updateSoundBtn();
					if (soundOn) tone(520, 0.08, 'sine', 0.15);
				});
				function ac() {
					if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
					if (audioCtx.state === 'suspended') audioCtx.resume();
					return audioCtx;
				}
				function tone(freq, dur, type, vol, when, slide) {
					if (!soundOn) return;
					try {
						const a = ac();
						const t0 = a.currentTime + (when || 0);
						const o = a.createOscillator();
						const g = a.createGain();
						o.type = type || 'sine';
						o.frequency.setValueAtTime(freq, t0);
						if (slide) o.frequency.exponentialRampToValueAtTime(Math.max(40, freq + slide), t0 + dur);
						g.gain.setValueAtTime(vol || 0.15, t0);
						g.gain.exponentialRampToValueAtTime(0.001, t0 + dur);
						o.connect(g).connect(a.destination);
						o.start(t0);
						o.stop(t0 + dur + 0.02);
					} catch {}
				}
				const sndShot = () => tone(700, 0.03, 'square', 0.02, 0, -200);
				const sndBoom = () => { tone(180, 0.15, 'sawtooth', 0.1, 0, -120); tone(90, 0.2, 'square', 0.07, 0.02, -50); };
				const sndItem = () => { tone(660, 0.08, 'sine', 0.14, 0, 200); tone(990, 0.1, 'sine', 0.1, 0.06, 150); };
				const sndPower = () => [523, 659, 784].forEach((f, i) => tone(f, 0.1, 'triangle', 0.15, i * 0.06, 60));
				const sndHit = () => { tone(220, 0.2, 'sawtooth', 0.14, 0, -140); };
				const sndOver = () => { tone(440, 0.2, 'sawtooth', 0.13, 0, -200); tone(280, 0.3, 'sawtooth', 0.1, 0.18, -160); };
				const sndBossWarn = () => { [0, 0.3, 0.6].forEach((d) => { tone(180, 0.22, 'sawtooth', 0.12, d, 60); tone(240, 0.22, 'sawtooth', 0.09, d + 0.11, -40); }); };
				const sndBossDown = () => { tone(300, 0.4, 'sawtooth', 0.16, 0, -240); tone(150, 0.5, 'square', 0.12, 0.15, -100); [880, 660, 440, 220].forEach((f, i) => tone(f, 0.16, 'triangle', 0.12, 0.3 + i * 0.1, -60)); };

				// --- sprites (이미지가 있으면 자동 사용, 없으면 벡터 폴백) ---
				// 검은 배경 스프라이트를 screen 블렌드로 그려 검정을 투명처럼 처리
				const SPRITES = {};
				[['ship', '/images/games/sprites/fly-ship.png'],
				 ['boss', '/images/games/sprites/fly-boss.png']].forEach(([k, src]) => {
					const im = new Image();
					im.onload = () => { SPRITES[k] = im; };
					im.src = src;
				});

				// --- state ---
				let ship, bullets, ebullets, enemies, items, particles, stars;
				let score, best, running = false, raf, lastT = 0, elapsed = 0;
				let fireCd = 0, spawnCd = 0, tankCd = 0, shakeAmp = 0;
				let target = null, keys = {};
				let boss = null, bossCd = 45000, bossLevel = 0, bossWarnT = 0;
				let shipPrevX = 0, bank = 0, trailCd = 0;
				best = Number(localStorage.getItem(BEST_KEY) || 0);
				bestEl.textContent = best;

				const FIRE_BASE = 300; // ms
				const rand = (a, b) => a + Math.random() * (b - a);

				function initStars() {
					stars = Array.from({length: 70}, () => ({
						x: Math.random() * W, y: Math.random() * H,
						s: rand(0.4, 1.6), r: rand(0.5, 1.6),
					}));
				}

				function newGame() {
					ship = {x: W / 2, y: H - 90, lv: 1, rate: 1, lives: 3, inv: 0};
					bullets = []; ebullets = []; enemies = []; items = []; particles = [];
					score = 0; elapsed = 0; fireCd = 0; spawnCd = 400; tankCd = 9000; shakeAmp = 0;
					target = null;
					boss = null; bossCd = 45000; bossLevel = 0; bossWarnT = 0;
					shipPrevX = ship.x; bank = 0; trailCd = 0;
					updateHud();
				}

				function updateHud() {
					scoreEl.textContent = score;
					weaponEl.textContent = 'Lv.' + ship.lv + (ship.rate > 1 ? ' ⚡' : '');
					livesEl.textContent = '❤️'.repeat(Math.max(0, ship.lives));
				}

				function burst(x, y, color, n) {
					for (let i = 0; i < n; i++) {
						const a = Math.random() * Math.PI * 2, sp = rand(1, 4);
						particles.push({x, y, vx: Math.cos(a) * sp, vy: Math.sin(a) * sp, life: 1, color, r: rand(1.5, 3.5)});
					}
				}

				// --- spawning ---
				function difficulty() { return Math.min(1, elapsed / 90000); } // 0→1 (90초에 최대)

				function spawnEnemy(kind, x) {
					const d = difficulty();
					if (kind === 'tank') {
						enemies.push({kind, x: x ?? rand(50, W - 50), y: -30, hp: 6 + Math.round(d * 6), r: 24,
							vy: 0.55 + d * 0.3, pts: 50, color: '#b78bff'});
					} else if (kind === 'zig') {
						enemies.push({kind, x: x ?? rand(60, W - 60), y: -24, hp: 2 + Math.round(d * 2), r: 16,
							vy: 1.2 + d * 1.1, ph: Math.random() * Math.PI * 2, pts: 20, color: '#00e5ff'});
					} else {
						enemies.push({kind: 'drone', x: x ?? rand(30, W - 30), y: -20, hp: 1 + Math.round(d * 1.5), r: 14,
							vy: 1.5 + d * 1.6, pts: 10, color: '#ff2fb3'});
					}
				}

				function dropItem(x, y, guaranteed) {
					if (!guaranteed && Math.random() > 0.18) return;
					const roll = Math.random();
					const type = roll < 0.6 ? 'P' : roll < 0.85 ? 'R' : 'L';
					items.push({x, y, vy: 1.1, type, ph: Math.random() * 6});
				}

				function applyItem(type) {
					if (type === 'P') {
						if (ship.lv < 5) { ship.lv++; sndPower(); } else { score += 50; sndItem(); }
					} else if (type === 'R') {
						ship.rate = Math.min(2.2, ship.rate * 1.15);
						sndItem();
					} else {
						if (ship.lives < 5) ship.lives++;
						sndItem();
					}
					updateHud();
				}

				// --- firing ---
				function fire() {
					const {x, y, lv} = ship;
					const B = (dx, dy, ang) => bullets.push({x: x + dx, y: y + dy, vx: Math.sin(ang || 0) * 7, vy: -(9 - Math.abs(ang || 0) * 2), r: 3.2});
					if (lv === 1) B(0, -18);
					else if (lv === 2) { B(-8, -14); B(8, -14); }
					else if (lv === 3) { B(0, -18); B(-10, -10, -0.24); B(10, -10, 0.24); }
					else if (lv === 4) { B(-7, -16); B(7, -16); B(-13, -8, -0.3); B(13, -8, 0.3); }
					else { B(0, -18); B(-8, -14, -0.16); B(8, -14, 0.16); B(-14, -8, -0.34); B(14, -8, 0.34); }
					sndShot();
				}

				// --- boss ---
				function spawnBoss() {
					bossLevel++;
					const hp = Math.round(90 * bossLevel * (1 + difficulty() * 0.6));
					boss = {x: W / 2, y: -90, ty: 118, hp, maxHp: hp, ph: 0, fireCd: 1500, pat: 0, hitT: -999, r: 54};
				}

				function updateBoss(dt, t) {
					if (boss.y < boss.ty) { boss.y += 1.7 * (dt / 16); return; }
					boss.ph += dt / 1000;
					boss.x = W / 2 + Math.sin(boss.ph) * (W / 2 - 92);
					boss.fireCd -= dt;
					if (boss.fireCd <= 0) {
						boss.pat = (boss.pat + 1) % 2;
						if (boss.pat === 0) {
							for (let k = -3; k <= 3; k++)
								ebullets.push({x: boss.x + k * 8, y: boss.y + 42, vx: k * 0.85, vy: 3.1});
						} else {
							const ang = Math.atan2(ship.y - boss.y, ship.x - boss.x);
							[-0.18, 0, 0.18].forEach((o) =>
								ebullets.push({x: boss.x, y: boss.y + 32, vx: Math.cos(ang + o) * 3.6, vy: Math.sin(ang + o) * 3.6}));
						}
						boss.fireCd = Math.max(650, 1500 - bossLevel * 130 - difficulty() * 300);
					}
					const dx = boss.x - ship.x, dy = boss.y - ship.y;
					if (dx * dx + dy * dy < (boss.r + 12) * (boss.r + 12)) damageShip(t);
				}

				function killBoss() {
					score += 300 + 200 * bossLevel;
					scoreEl.textContent = score;
					burst(boss.x, boss.y, '#b78bff', 60);
					burst(boss.x - 34, boss.y + 14, '#ff2fb3', 28);
					burst(boss.x + 34, boss.y - 12, '#00e5ff', 28);
					shakeAmp = 15;
					sndBossDown();
					['P', 'R', 'L'].forEach((tp, i) => items.push({x: boss.x + (i - 1) * 38, y: boss.y, vy: 1.1, type: tp, ph: i}));
					boss = null;
					bossCd = 50000;
					bossWarnT = 0;
				}

				function damageShip(t) {
					if (t < ship.inv) return;
					ship.lives--;
					ship.lv = Math.max(1, ship.lv - 1); // 무기 다운그레이드
					ship.inv = t + 2000;
					shakeAmp = 9;
					sndHit();
					burst(ship.x, ship.y, '#3ef58b', 22);
					updateHud();
					if (ship.lives <= 0) endGame();
				}

				function endGame() {
					running = false;
					sndOver();
					if (score > best) {
						best = score;
						localStorage.setItem(BEST_KEY, best);
						bestEl.textContent = best;
					}
					ovTitle.textContent = '격추당했다!';
					ovSub.textContent = `점수 ${score} · 최고 기록 ${best}`;
					startBtn.textContent = '다시 출격!';
					shareBtn.hidden = false;
					setTimeout(() => overlay.classList.remove('hidden'), 600);
				}

				// --- update & draw ---
				function update(dt, t) {
					elapsed += dt;
					const d = difficulty();

					// 이동: 포인터 타깃 따라가기 + 키보드
					if (target) {
						ship.x += (target.x - ship.x) * Math.min(1, dt / 55);
						ship.y += (target.y - ship.y) * Math.min(1, dt / 55);
					}
					const kv = 5.2 * (dt / 16);
					if (keys.left) ship.x -= kv;
					if (keys.right) ship.x += kv;
					if (keys.up) ship.y -= kv;
					if (keys.down) ship.y += kv;
					ship.x = Math.max(18, Math.min(W - 18, ship.x));
					ship.y = Math.max(H * 0.35, Math.min(H - 26, ship.y));

					// 뱅킹(좌우 이동 시 기체 기울기) + 엔진 트레일
					const vx = ship.x - shipPrevX;
					shipPrevX = ship.x;
					bank += (Math.max(-0.4, Math.min(0.4, vx * 0.045)) - bank) * Math.min(1, dt / 90);
					trailCd -= dt;
					if (trailCd <= 0) {
						trailCd = 28;
						particles.push({x: ship.x + rand(-4, 4), y: ship.y + 16, vx: rand(-0.3, 0.3), vy: rand(1.5, 2.5),
							life: 0.55, color: '#00e5ff', r: rand(1.2, 2.4)});
					}

					// 자동 발사
					fireCd -= dt;
					if (fireCd <= 0) { fire(); fireCd = FIRE_BASE / ship.rate; }

					// 스폰
					spawnCd -= dt;
					if (spawnCd <= 0) {
						spawnEnemy(Math.random() < 0.3 + d * 0.2 ? 'zig' : 'drone');
						spawnCd = Math.max(260, 950 - d * 650) * (boss ? 1.9 : 1); // 보스전엔 잡몹 감소
					}
					tankCd -= dt;
					if (tankCd <= 0) { spawnEnemy('tank'); tankCd = Math.max(6000, 12000 - d * 5000); }

					// 보스
					if (!boss) {
						bossCd -= dt;
						if (bossCd <= 2600 && !bossWarnT) { bossWarnT = t + 2600; sndBossWarn(); }
						if (bossCd <= 0) spawnBoss();
					} else updateBoss(dt, t);

					// 총알
					for (let i = bullets.length - 1; i >= 0; i--) {
						const b = bullets[i];
						b.x += b.vx * (dt / 16); b.y += b.vy * (dt / 16);
						if (b.y < -12 || b.x < -12 || b.x > W + 12) { bullets.splice(i, 1); continue; }
						if (boss && boss.y > -30) {
							const dx = b.x - boss.x, dy = b.y - boss.y;
							if (dx * dx + dy * dy < boss.r * boss.r) {
								bullets.splice(i, 1);
								boss.hp--;
								boss.hitT = t;
								burst(b.x, b.y, '#b78bff', 3);
								if (boss.hp <= 0) killBoss();
							}
						}
					}
					// 적탄
					for (let i = ebullets.length - 1; i >= 0; i--) {
						const b = ebullets[i];
						b.x += b.vx * (dt / 16); b.y += b.vy * (dt / 16);
						if (b.y > H + 12) { ebullets.splice(i, 1); continue; }
						const dx = b.x - ship.x, dy = b.y - ship.y;
						if (dx * dx + dy * dy < 15 * 15) { ebullets.splice(i, 1); damageShip(t); }
					}

					// 적
					for (let i = enemies.length - 1; i >= 0; i--) {
						const e = enemies[i];
						e.y += e.vy * (dt / 16);
						if (e.kind === 'zig') { e.ph += dt / 300; e.x += Math.sin(e.ph) * 1.8 * (dt / 16); }
						// 사격(드론, 30초 이후)
						if (e.kind === 'drone' && elapsed > 30000 && Math.random() < dt * 0.00025 * (1 + d)) {
							const ang = Math.atan2(ship.y - e.y, ship.x - e.x);
							ebullets.push({x: e.x, y: e.y, vx: Math.cos(ang) * 3.4, vy: Math.sin(ang) * 3.4});
						}
						if (e.y > H + 40) { enemies.splice(i, 1); continue; }
						// 기체 충돌
						const dx = e.x - ship.x, dy = e.y - ship.y;
						if (dx * dx + dy * dy < (e.r + 13) * (e.r + 13)) {
							burst(e.x, e.y, e.color, 14);
							enemies.splice(i, 1);
							damageShip(t);
							continue;
						}
						// 피격
						for (let j = bullets.length - 1; j >= 0; j--) {
							const b = bullets[j];
							const bx = b.x - e.x, by = b.y - e.y;
							if (bx * bx + by * by < (e.r + b.r) * (e.r + b.r)) {
								bullets.splice(j, 1);
								e.hp--;
								if (e.hp <= 0) {
									score += e.pts;
									scoreEl.textContent = score;
									burst(e.x, e.y, e.color, e.kind === 'tank' ? 26 : 14);
									if (e.kind === 'tank') shakeAmp = Math.max(shakeAmp, 5);
									sndBoom();
									dropItem(e.x, e.y, e.kind === 'tank');
									enemies.splice(i, 1);
								}
								break;
							}
						}
					}

					// 아이템 (근처에 가면 자석처럼 끌려옴)
					for (let i = items.length - 1; i >= 0; i--) {
						const it = items[i];
						it.y += it.vy * (dt / 16);
						it.ph += dt / 250;
						if (it.y > H + 20) { items.splice(i, 1); continue; }
						const mx = ship.x - it.x, my = ship.y - it.y;
						if (mx * mx + my * my < 95 * 95) {
							it.x += mx * 0.07 * (dt / 16);
							it.y += my * 0.07 * (dt / 16);
						}
						const dx = it.x - ship.x, dy = it.y - ship.y;
						if (dx * dx + dy * dy < 30 * 30) {
							applyItem(it.type);
							burst(it.x, it.y, '#ffd166', 10);
							items.splice(i, 1);
						}
					}

					// 파티클·별
					for (let i = particles.length - 1; i >= 0; i--) {
						const p = particles[i];
						p.x += p.vx * (dt / 16); p.y += p.vy * (dt / 16);
						p.life -= dt / 550;
						if (p.life <= 0) particles.splice(i, 1);
					}
					stars.forEach((s) => {
						s.y += s.s * (1 + d) * (dt / 16);
						if (s.y > H) { s.y = -2; s.x = Math.random() * W; }
					});
				}

				function drawShip(t) {
					if (t < ship.inv && Math.floor(t / 120) % 2 === 0) return; // 무적 깜빡임
					const {x, y} = ship;
					ctx.save();
					ctx.translate(x, y);
					ctx.rotate(bank); // 좌우 이동 시 기울어지는 비행
					ctx.translate(-x, -y);
					// 트윈 엔진 불꽃
					ctx.fillStyle = '#00e5ff';
					ctx.shadowColor = '#00e5ff';
					ctx.shadowBlur = 12;
					const fl = 9 + Math.sin(t / 38) * 3.5;
					[-6, 6].forEach((ox) => {
						ctx.beginPath();
						ctx.moveTo(x + ox - 3, y + 11);
						ctx.lineTo(x + ox, y + 11 + fl);
						ctx.lineTo(x + ox + 3, y + 11);
						ctx.closePath(); ctx.fill();
					});
					if (SPRITES.ship) {
						// 검은 배경 스프라이트를 screen 블렌드로(검정=투명)
						ctx.globalCompositeOperation = 'screen';
						const s = 58;
						ctx.drawImage(SPRITES.ship, x - s / 2, y - s / 2 - 2, s, s);
						ctx.globalCompositeOperation = 'source-over';
					} else {
						// 기체(2톤 + 날개끝 등)
						ctx.fillStyle = '#1d7a4d';
						ctx.shadowColor = '#3ef58b';
						ctx.shadowBlur = 16;
						ctx.beginPath();
						ctx.moveTo(x, y - 20);
						ctx.lineTo(x + 16, y + 11); ctx.lineTo(x + 6, y + 7); ctx.lineTo(x, y + 13);
						ctx.lineTo(x - 6, y + 7); ctx.lineTo(x - 16, y + 11);
						ctx.closePath(); ctx.fill();
						ctx.fillStyle = '#3ef58b';
						ctx.shadowBlur = 10;
						ctx.beginPath();
						ctx.moveTo(x, y - 20);
						ctx.lineTo(x + 7, y + 5); ctx.lineTo(x, y + 9); ctx.lineTo(x - 7, y + 5);
						ctx.closePath(); ctx.fill();
						// 콕핏
						ctx.fillStyle = '#eaffff';
						ctx.shadowColor = '#ffffff';
						ctx.shadowBlur = 7;
						ctx.beginPath(); ctx.ellipse(x, y - 5, 2.6, 4.2, 0, 0, Math.PI * 2); ctx.fill();
						// 날개끝 항법등(깜빡임)
						if (Math.floor(t / 260) % 2 === 0) {
							ctx.fillStyle = '#ff5d5d';
							ctx.shadowColor = '#ff5d5d';
							ctx.beginPath(); ctx.arc(x - 15, y + 9, 1.7, 0, Math.PI * 2); ctx.fill();
							ctx.fillStyle = '#5dff8a';
							ctx.shadowColor = '#5dff8a';
							ctx.beginPath(); ctx.arc(x + 15, y + 9, 1.7, 0, Math.PI * 2); ctx.fill();
						}
					}
					ctx.restore();
				}

				function drawBoss(t) {
					const b = boss;
					const flash = t - b.hitT < 70;
					ctx.save();
					ctx.translate(b.x, b.y);
					if (SPRITES.boss) {
						ctx.globalCompositeOperation = 'screen';
						const s = b.r * 2.6;
						ctx.drawImage(SPRITES.boss, -s / 2, -s / 2, s, s);
						ctx.globalCompositeOperation = 'source-over';
						if (flash) {
							ctx.globalAlpha = 0.45;
							ctx.fillStyle = '#fff';
							ctx.beginPath(); ctx.arc(0, 0, b.r, 0, Math.PI * 2); ctx.fill();
						}
					} else {
						// 좌우 날개
						ctx.fillStyle = flash ? '#ffffff' : '#5b3aa8';
						ctx.shadowColor = '#b78bff';
						ctx.shadowBlur = 22;
						[[-1, 0], [1, 0]].forEach(([s]) => {
							ctx.beginPath();
							ctx.moveTo(s * b.r * 1.7, 8);
							ctx.lineTo(s * b.r * 0.55, -26);
							ctx.lineTo(s * b.r * 0.5, 30);
							ctx.closePath(); ctx.fill();
						});
						// 본체 육각
						ctx.fillStyle = flash ? '#ffffff' : '#8b5cf6';
						ctx.beginPath();
						for (let i = 0; i < 6; i++) {
							const a = Math.PI / 3 * i + Math.PI / 6;
							ctx[i ? 'lineTo' : 'moveTo'](b.r * 0.95 * Math.cos(a), b.r * 0.78 * Math.sin(a));
						}
						ctx.closePath(); ctx.fill();
						// 장갑 라인
						ctx.strokeStyle = 'rgba(255,255,255,0.25)';
						ctx.lineWidth = 2;
						ctx.stroke();
						// 맥동 코어
						const core = b.r * 0.3 * (1 + 0.12 * Math.sin(t / 140));
						ctx.fillStyle = '#ff2fb3';
						ctx.shadowColor = '#ff2fb3';
						ctx.shadowBlur = 24;
						ctx.beginPath(); ctx.arc(0, 4, core, 0, Math.PI * 2); ctx.fill();
						ctx.fillStyle = '#ffd9ef';
						ctx.shadowBlur = 8;
						ctx.beginPath(); ctx.arc(0, 4, core * 0.42, 0, Math.PI * 2); ctx.fill();
						// 포탑
						ctx.fillStyle = '#2a1f4d';
						[[-b.r * 0.55, 20], [b.r * 0.55, 20]].forEach(([px, py]) => {
							ctx.beginPath(); ctx.arc(px, py, 7, 0, Math.PI * 2); ctx.fill();
						});
					}
					ctx.restore();
					// 보스 HP 바
					const bw = W - 70, bx = 35, by = 12;
					ctx.save();
					ctx.fillStyle = 'rgba(255,255,255,0.12)';
					ctx.beginPath(); ctx.roundRect(bx, by, bw, 9, 5); ctx.fill();
					ctx.fillStyle = '#ff2fb3';
					ctx.shadowColor = '#ff2fb3';
					ctx.shadowBlur = 10;
					ctx.beginPath(); ctx.roundRect(bx, by, Math.max(0, bw * (b.hp / b.maxHp)), 9, 5); ctx.fill();
					ctx.shadowBlur = 0;
					ctx.fillStyle = '#fff';
					ctx.font = '800 11px system-ui, sans-serif';
					ctx.textAlign = 'left';
					ctx.fillText('BOSS Lv.' + bossLevel, bx, by + 22);
					ctx.restore();
				}

				function drawEnemy(e) {
					ctx.save();
					ctx.translate(e.x, e.y);
					ctx.fillStyle = e.color;
					ctx.shadowColor = e.color;
					ctx.shadowBlur = 12;
					ctx.beginPath();
					if (e.kind === 'tank') {
						for (let i = 0; i < 6; i++) {
							const a = Math.PI / 3 * i + Math.PI / 6;
							ctx[i ? 'lineTo' : 'moveTo'](e.r * Math.cos(a), e.r * Math.sin(a));
						}
					} else if (e.kind === 'zig') {
						ctx.moveTo(0, -e.r); ctx.lineTo(e.r, 0); ctx.lineTo(0, e.r); ctx.lineTo(-e.r, 0);
					} else {
						ctx.moveTo(0, e.r); ctx.lineTo(e.r, -e.r * 0.7); ctx.lineTo(-e.r, -e.r * 0.7);
					}
					ctx.closePath(); ctx.fill();
					// 콕핏·코어(기계 느낌)
					ctx.shadowBlur = 4;
					ctx.fillStyle = 'rgba(11,14,20,0.75)';
					ctx.beginPath();
					ctx.arc(0, e.kind === 'drone' ? -e.r * 0.15 : 0, e.r * 0.42, 0, Math.PI * 2);
					ctx.fill();
					ctx.fillStyle = 'rgba(255,255,255,0.9)';
					ctx.beginPath();
					ctx.arc(0, e.kind === 'drone' ? -e.r * 0.15 : 0, e.r * 0.16 + 1, 0, Math.PI * 2);
					ctx.fill();
					// HP 링(탱크)
					if (e.kind === 'tank') {
						ctx.strokeStyle = '#fff';
						ctx.globalAlpha = 0.5;
						ctx.lineWidth = 2;
						ctx.beginPath();
						ctx.arc(0, 0, e.r + 5, -Math.PI / 2, -Math.PI / 2 + (e.hp / (6 + Math.round(difficulty() * 6))) * Math.PI * 2);
						ctx.stroke();
					}
					ctx.restore();
				}

				const ITEM_STYLE = {P: {c: '#3ef58b', icon: '🔫'}, R: {c: '#00e5ff', icon: '⚡'}, L: {c: '#ff2fb3', icon: '💖'}};

				function draw(t) {
					ctx.fillStyle = '#0b0e14';
					ctx.fillRect(0, 0, W, H);
					ctx.save();
					if (shakeAmp > 0.3) {
						ctx.translate((Math.random() * 2 - 1) * shakeAmp, (Math.random() * 2 - 1) * shakeAmp);
						shakeAmp *= 0.9;
					}
					// 별
					ctx.fillStyle = 'rgba(255,255,255,0.5)';
					stars.forEach((s) => { ctx.globalAlpha = 0.2 + s.s * 0.3; ctx.fillRect(s.x, s.y, s.r, s.r + s.s); });
					ctx.globalAlpha = 1;
					// 내 총알: 위로 뻗는 초록 레이저 볼트(빛나는 머리 + 꼬리)
					bullets.forEach((b) => {
						ctx.save();
						ctx.translate(b.x, b.y);
						ctx.rotate(Math.atan2(b.vy, b.vx) + Math.PI / 2);
						const g = ctx.createLinearGradient(0, -10, 0, 12);
						g.addColorStop(0, '#ffffff');
						g.addColorStop(0.35, '#8dffc0');
						g.addColorStop(1, 'rgba(62,245,139,0)');
						ctx.fillStyle = g;
						ctx.shadowColor = '#3ef58b';
						ctx.shadowBlur = 10;
						ctx.beginPath();
						ctx.roundRect(-2.2, -10, 4.4, 22, 2.2);
						ctx.fill();
						ctx.restore();
					});
					// 적탄: 빨간 불덩이 + 꼬리(위험 신호)
					ebullets.forEach((b) => {
						ctx.save();
						ctx.fillStyle = 'rgba(255,85,51,0.3)';
						ctx.beginPath();
						ctx.arc(b.x - b.vx * 2.4, b.y - b.vy * 2.4, 6, 0, Math.PI * 2);
						ctx.fill();
						ctx.fillStyle = '#ff5533';
						ctx.shadowColor = '#ff5533';
						ctx.shadowBlur = 14;
						ctx.beginPath();
						ctx.arc(b.x, b.y, 4.6, 0, Math.PI * 2);
						ctx.fill();
						ctx.shadowBlur = 0;
						ctx.fillStyle = '#ffe3d6';
						ctx.beginPath();
						ctx.arc(b.x, b.y, 2, 0, Math.PI * 2);
						ctx.fill();
						ctx.restore();
					});
					enemies.forEach(drawEnemy);
					if (boss) drawBoss(t);
					// 보스 경보
					if (bossWarnT && t < bossWarnT && !boss) {
						ctx.save();
						ctx.globalAlpha = 0.55 + 0.45 * Math.sin(t / 90);
						ctx.fillStyle = '#ff5533';
						ctx.shadowColor = '#ff5533';
						ctx.shadowBlur = 22;
						ctx.font = '800 30px system-ui, sans-serif';
						ctx.textAlign = 'center';
						ctx.fillText('⚠ BOSS 접근 중 ⚠', W / 2, H * 0.3);
						ctx.restore();
					}
					// 아이템: 보급상자(이모지 + 펄스 링 = "먹는 것" 신호)
					items.forEach((it) => {
						const st = ITEM_STYLE[it.type];
						const bob = Math.sin(it.ph) * 3;
						const pulse = 1 + 0.14 * Math.sin(it.ph * 2.2);
						ctx.save();
						ctx.translate(it.x, it.y + bob);
						// 바깥 펄스 링
						ctx.strokeStyle = st.c;
						ctx.shadowColor = st.c;
						ctx.shadowBlur = 16;
						ctx.globalAlpha = 0.55;
						ctx.lineWidth = 2;
						ctx.beginPath();
						ctx.arc(0, 0, 20 * pulse, 0, Math.PI * 2);
						ctx.stroke();
						ctx.globalAlpha = 1;
						// 상자 본체
						ctx.fillStyle = 'rgba(11,14,20,0.92)';
						ctx.lineWidth = 2.4;
						ctx.beginPath();
						ctx.roundRect(-14, -14, 28, 28, 9);
						ctx.fill();
						ctx.stroke();
						ctx.shadowBlur = 0;
						ctx.font = '16px serif';
						ctx.textAlign = 'center';
						ctx.textBaseline = 'middle';
						ctx.fillText(st.icon, 0, 1);
						ctx.restore();
					});
					// 파티클
					particles.forEach((p) => {
						ctx.save();
						ctx.globalAlpha = Math.max(0, p.life);
						ctx.fillStyle = p.color;
						ctx.shadowColor = p.color;
						ctx.shadowBlur = 8;
						ctx.beginPath(); ctx.arc(p.x, p.y, p.r * p.life, 0, Math.PI * 2); ctx.fill();
						ctx.restore();
					});
					drawShip(t);
					// 시작 5초 안내 배너
					if (running && elapsed < 5000) {
						const a = elapsed < 4000 ? 1 : 1 - (elapsed - 4000) / 1000;
						ctx.save();
						ctx.globalAlpha = a * 0.95;
						ctx.fillStyle = 'rgba(11,14,20,0.75)';
						ctx.beginPath();
						ctx.roundRect(W / 2 - 165, 84, 330, 62, 12);
						ctx.fill();
						ctx.textAlign = 'center';
						ctx.fillStyle = '#ffd166';
						ctx.font = '800 16px system-ui, sans-serif';
						ctx.fillText('상자에 담긴 🔫 ⚡ 💖 = 먹는 아이템!', W / 2, 108);
						ctx.fillStyle = '#ff5533';
						ctx.font = '700 14px system-ui, sans-serif';
						ctx.fillText('빨간 불덩이는 적탄, 피하세요!', W / 2, 132);
						ctx.restore();
					}
					ctx.restore();
				}

				function loop(t) {
					const dt = lastT ? Math.min(50, t - lastT) : 16;
					lastT = t;
					if (running) update(dt, t);
					draw(t);
					if (running || particles.length) raf = requestAnimationFrame(loop);
				}

				// --- input ---
				function setTarget(clientX, clientY) {
					const rect = canvas.getBoundingClientRect();
					const x = ((clientX - rect.left) / rect.width) * W;
					const y = ((clientY - rect.top) / rect.height) * H;
					target = {x, y: y - 46}; // 손가락 위 46px에 떠서 가려지지 않게
				}
				canvas.addEventListener('pointermove', (e) => { if (running) setTarget(e.clientX, e.clientY); });
				canvas.addEventListener('pointerdown', (e) => { if (running) { e.preventDefault(); setTarget(e.clientX, e.clientY); } });
				canvas.addEventListener('touchmove', (e) => e.preventDefault(), {passive: false});
				document.addEventListener('keydown', (e) => {
					const m = {ArrowLeft: 'left', ArrowRight: 'right', ArrowUp: 'up', ArrowDown: 'down',
						a: 'left', d: 'right', w: 'up', s: 'down'};
					if (m[e.key]) { e.preventDefault(); keys[m[e.key]] = true; target = null; }
				});
				document.addEventListener('keyup', (e) => {
					const m = {ArrowLeft: 'left', ArrowRight: 'right', ArrowUp: 'up', ArrowDown: 'down',
						a: 'left', d: 'right', w: 'up', s: 'down'};
					if (m[e.key]) keys[m[e.key]] = false;
				});

				startBtn.addEventListener('click', () => {
					newGame();
					overlay.classList.add('hidden');
					running = true;
					lastT = 0;
					cancelAnimationFrame(raf);
					raf = requestAnimationFrame(loop);
				});
				shareBtn.addEventListener('click', async () => {
					const text = `네온 스카이에서 ${score}점 격추! 나를 이겨봐 👉 ${location.href}`;
					try {
						await navigator.clipboard.writeText(text);
						shareBtn.textContent = '복사 완료!';
					} catch {
						shareBtn.textContent = text;
					}
					setTimeout(() => (shareBtn.textContent = '점수 공유'), 1600);
				});

				initStars();
				newGame();
				draw(0);

				// test hook
				window.__fly = {
					score: () => score,
					lives: () => ship.lives,
					lv: () => ship.lv,
					rate: () => ship.rate,
					running: () => running,
					shipPos: () => ({x: ship.x, y: ship.y}),
					setShip: (x, y) => { ship.x = x; ship.y = y; target = null; },
					spawnItemAt: (type, x, y) => items.push({x, y, vy: 1, type, ph: 0}),
					spawnEnemyAt: (kind, x) => spawnEnemy(kind, x),
					counts: () => ({enemies: enemies.length, items: items.length, bullets: bullets.length}),
					setLv: (n) => { ship.lv = Math.max(1, Math.min(5, n)); updateHud(); },
					tick: (dt) => { if (running) { update(dt || 16, performance.now()); draw(performance.now()); } },
					forceBoss: () => { if (!boss) spawnBoss(); },
					bossHp: () => (boss ? boss.hp : null),
					bossActive: () => !!boss,
				};
			})();
		</script>
	</body>
</html>

<style>
	/* touch-action: manipulation = 더블탭 확대 차단 */
	#flygame { max-width: 560px; margin: 0 auto; touch-action: manipulation; }
	.game-hero { padding: 2rem 0 1.4rem; text-align: center; }
	.game-hero h1 { font-size: clamp(1.9rem, 5vw, 2.6rem); margin: 0.5rem 0; }
	.neon { color: var(--accent); text-shadow: 0 0 24px var(--accent-glow); }
	.lead { color: var(--text-muted); }

	.hud { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.55rem; margin-bottom: 0.9rem; }
	.hud-item {
		background: var(--bg-elev); border: 1px solid var(--border); border-radius: 999px;
		padding: 0.4em 1em; color: var(--text-muted); font-size: 0.9rem; font-weight: 600;
	}
	.hud-item strong { color: var(--accent); margin-left: 0.3em; }
	.tool-btn {
		cursor: pointer; line-height: 1.4;
		touch-action: manipulation; user-select: none; -webkit-user-select: none;
	}
	.tool-btn:hover { border-color: var(--accent); }

	/* 폰·패드·PC 자동맞춤: 세로 480x640 보드가 화면 높이를 넘지 않게 */
	.stage { position: relative; width: min(100%, 54vh); margin-inline: auto; }
	#board {
		display: block; width: 100%; height: auto; touch-action: none;
		background: #0b0e14; border: 1px solid var(--border); border-radius: var(--radius);
		box-shadow: 0 0 40px rgba(0, 229, 255, 0.07);
		cursor: crosshair;
	}
	.overlay {
		position: absolute; inset: 0; display: flex; flex-direction: column;
		align-items: center; justify-content: center; gap: 0.7rem;
		background:
			linear-gradient(180deg, rgba(11, 14, 20, 0.35), rgba(11, 14, 20, 0.88)),
			url('/images/games/fly-title.jpg') center 32% / cover no-repeat;
		border-radius: var(--radius); text-align: center; padding: 1rem;
	}
	.overlay.hidden { display: none; }
	.overlay h2 { margin: 0; font-size: 1.9rem; text-shadow: 0 2px 16px rgba(0, 0, 0, 0.9); }
	.overlay p { margin: 0; color: #d5dbe8; text-shadow: 0 1px 8px rgba(0, 0, 0, 0.9); }

	.howto { margin: 2.2rem 0 3rem; }
	.howto h2 { font-size: 1.25rem; margin: 1.4rem 0 0.6rem; }
	.howto ul { color: var(--text-muted); padding-left: 1.2em; }
	.howto li { margin-bottom: 0.35em; }
</style>
