---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = '네온 크래프트 — 2D 블록 채굴·건축 샌드박스 | 게임월드7';
const description =
	'블록을 캐고 다시 쌓아 나만의 세계를 짓는 2D 샌드박스 게임. 랜덤 지형, 광석 채굴, 다이아몬드 찾기, 자동 저장까지. 무료 · 설치 없음.';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div id="craftgame">
				<section class="game-hero">
					<span class="tag">PLAY · 샌드박스</span>
					<h1>⛏️ <span class="neon">네온 크래프트</span></h1>
					<p class="lead">블록을 <strong>캐고, 모으고, 다시 쌓아서</strong> 나만의 세계를 지으세요. 세계는 자동 저장됩니다!</p>
				</section>

				<div class="hud">
					<div class="hud-item">💎 다이아 <strong id="dia">0</strong>/3</div>
					<button class="hud-item tool-btn" id="modeBtn" type="button">⛏️ 캐기</button>
					<button class="hud-item tool-btn" id="resetBtn" type="button">🌍 새 세계</button>
					<button class="hud-item tool-btn" id="soundBtn" type="button" aria-label="효과음">🔊</button>
				</div>

				<div class="stage">
					<canvas id="board" width="480" height="400" aria-label="네온 크래프트 세계"></canvas>
					<div class="overlay hidden" id="overlay">
						<div class="ov-emoji" id="ov-emoji">🎉</div>
						<h2 id="ov-title">다이아몬드 3개!</h2>
						<p id="ov-sub">진짜 광부님이네요!</p>
						<button class="btn" id="okBtn" type="button">계속 짓기</button>
					</div>
				</div>

				<div class="hotbar" id="hotbar" aria-label="블록 인벤토리"></div>

				<div class="pad">
					<div class="pad-move">
						<button type="button" id="btnL" aria-label="왼쪽">◀</button>
						<button type="button" id="btnR" aria-label="오른쪽">▶</button>
					</div>
					<button type="button" id="btnJ" aria-label="점프">⬆ 점프</button>
				</div>

				<section class="howto">
					<h2>조작법</h2>
					<ul>
						<li><strong>PC</strong> — A·D(←·→) 이동, W·스페이스 점프. <strong>왼쪽 클릭 = 캐기, 오른쪽 클릭 = 놓기.</strong></li>
						<li><strong>모바일</strong> — 아래 이동·점프 버튼 + 화면 탭. 상단 <strong>⛏️/🧱 버튼</strong>으로 캐기·놓기 모드를 바꿉니다.</li>
						<li>캔 블록은 아래 <strong>인벤토리</strong>에 쌓입니다. 놓을 블록을 인벤토리에서 골라 빈 곳을 탭하세요(가까운 곳만 가능).</li>
						<li>세계와 인벤토리는 <strong>자동 저장</strong>됩니다. 🌍 새 세계 버튼으로 새 지형을 만들 수 있어요.</li>
					</ul>
					<h2>놀이 아이디어</h2>
					<ul>
						<li>땅속 깊이 파 내려가면 석탄 → 철 → 금 → <strong>💎 다이아몬드</strong>가 나옵니다. 3개를 찾아보세요!</li>
						<li>나무를 캐서 집 짓기, 돌로 탑 쌓기, 하늘 다리 만들기… 정답은 없습니다.</li>
						<li>주의: 발밑을 파면 떨어집니다. 마인크래프트의 오랜 격언, "자기 발밑은 파지 마라."</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const canvas = document.getElementById('board');
				const ctx = canvas.getContext('2d');
				const VW = canvas.width, VH = canvas.height;
				const TILE = 20, WC = 80, WR = 50; // 세계 80x50 블록
				const WPX = WC * TILE, HPX = WR * TILE;
				const SAVE_KEY = 'gw7_craft_save_v1';
				const diaEl = document.getElementById('dia');
				const modeBtn = document.getElementById('modeBtn');
				const resetBtn = document.getElementById('resetBtn');
				const overlay = document.getElementById('overlay');
				const okBtn = document.getElementById('okBtn');
				const hotbarEl = document.getElementById('hotbar');

				// 블록 정의: [이름, 윗면색, 본체색, 캘 때 얻는 id(0=자신), 캐기가능]
				const AIR = 0, BEDROCK = 11;
				const BLOCKS = {
					1: {n: '잔디', top: '#3ef58b', body: '#2a8f57', drop: 2},
					2: {n: '흙', top: '#a06a45', body: '#7d4f33'},
					3: {n: '돌', top: '#9aa6bd', body: '#6b7688'},
					4: {n: '나무', top: '#c98d4e', body: '#8f6134'},
					5: {n: '잎', top: '#57d977', body: '#2f9e4e'},
					7: {n: '석탄', top: '#6b7688', body: '#454e5e', ore: '#20242c'},
					8: {n: '철', top: '#6b7688', body: '#67707f', ore: '#e8c9a0'},
					9: {n: '금', top: '#6b7688', body: '#67707f', ore: '#ffd166'},
					10: {n: '💎', top: '#6b7688', body: '#67707f', ore: '#7df3ff'},
					11: {n: '기반암', top: '#2a2f3a', body: '#171b23'},
				};
				const PLACEABLE = [2, 3, 4, 5, 1, 7, 8, 9, 10];

				// --- sound ---
				const soundBtn = document.getElementById('soundBtn');
				const SOUND_KEY = 'gw7_craft_sound';
				let soundOn = localStorage.getItem(SOUND_KEY) !== '0';
				let audioCtx = null;
				const updateSoundBtn = () => { soundBtn.textContent = soundOn ? '🔊' : '🔇'; };
				updateSoundBtn();
				soundBtn.addEventListener('click', () => {
					soundOn = !soundOn;
					localStorage.setItem(SOUND_KEY, soundOn ? '1' : '0');
					updateSoundBtn();
					if (soundOn) tone(520, 0.07, 'sine', 0.14);
				});
				function ac() {
					if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
					if (audioCtx.state === 'suspended') audioCtx.resume();
					return audioCtx;
				}
				function tone(freq, dur, type, vol, when, slide) {
					if (!soundOn) return;
					try {
						const a = ac();
						const t0 = a.currentTime + (when || 0);
						const o = a.createOscillator();
						const g = a.createGain();
						o.type = type || 'sine';
						o.frequency.setValueAtTime(freq, t0);
						if (slide) o.frequency.exponentialRampToValueAtTime(Math.max(40, freq + slide), t0 + dur);
						g.gain.setValueAtTime(vol || 0.15, t0);
						g.gain.exponentialRampToValueAtTime(0.001, t0 + dur);
						o.connect(g).connect(a.destination);
						o.start(t0);
						o.stop(t0 + dur + 0.02);
					} catch {}
				}
				const sndDig = (id) => tone(id === 3 ? 220 : 320, 0.06, 'square', 0.07, 0, -80);
				const sndPlace = () => tone(180, 0.06, 'square', 0.08, 0, 60);
				const sndJump = () => tone(300, 0.08, 'sine', 0.06, 0, 180);
				const sndOre = () => { tone(660, 0.08, 'triangle', 0.12, 0, 150); tone(880, 0.08, 'sine', 0.08, 0.05, 120); };
				const sndDia = () => [659, 784, 1047, 1319].forEach((f, i) => tone(f, 0.16, 'triangle', 0.15, i * 0.09, 40));

				// --- world ---
				let G, inv, player, diamonds, praised, mode = 'dig', selected = 2;
				let camX = 0, camY = 0, raf, lastT = 0, saveCd = 8000;
				let fx = []; // 채굴 파티클

				const idx = (c, r) => r * WC + c;
				const tileAt = (c, r) => (c < 0 || r < 0 || c >= WC || r >= WR ? BEDROCK : G[idx(c, r)]);
				const solid = (id) => id !== AIR;

				function genWorld() {
					G = new Uint8Array(WC * WR);
					let h = 16;
					const surface = [];
					for (let c = 0; c < WC; c++) {
						h += Math.round((Math.random() - 0.5) * 2);
						h = Math.max(10, Math.min(24, h));
						surface.push(h);
						for (let r = 0; r < WR; r++) {
							let id = AIR;
							if (r === WR - 1) id = BEDROCK;
							else if (r > h + 4) {
								id = 3;
								const depth = r - h;
								const roll = Math.random();
								if (depth > 22 && roll < 0.015) id = 10;      // 다이아
								else if (depth > 14 && roll < 0.03) id = 9;   // 금
								else if (depth > 8 && roll < 0.05) id = 8;    // 철
								else if (roll < 0.06) id = 7;                 // 석탄
							} else if (r > h) id = 2;
							else if (r === h) id = 1;
							G[idx(c, r)] = id;
						}
					}
					// 나무
					for (let c = 3; c < WC - 3; c += 5 + Math.floor(Math.random() * 6)) {
						const r = surface[c];
						if (tileAt(c, r) !== 1) continue;
						const th = 3 + Math.floor(Math.random() * 2);
						for (let k = 1; k <= th; k++) G[idx(c, r - k)] = 4;
						for (let dc = -2; dc <= 2; dc++)
							for (let dr = 0; dr <= 2; dr++) {
								const cc = c + dc, rr = r - th - dr;
								if (cc < 0 || cc >= WC || rr < 0) continue;
								if (Math.abs(dc) === 2 && dr === 2) continue;
								if (G[idx(cc, rr)] === AIR) G[idx(cc, rr)] = 5;
							}
					}
					inv = {2: 0, 3: 0, 4: 0, 5: 0, 1: 0, 7: 0, 8: 0, 9: 0, 10: 0};
					diamonds = 0;
					praised = false;
					const sc = Math.floor(WC / 2);
					player = {x: sc * TILE + 3, y: (surface[sc] - 2) * TILE - 2, vx: 0, vy: 0, w: 14, h: 36, face: 1, onG: false};
				}

				function save() {
					try {
						localStorage.setItem(SAVE_KEY, JSON.stringify({
							g: Array.from(G), inv, d: diamonds, p: praised,
							x: Math.round(player.x), y: Math.round(player.y),
						}));
					} catch {}
				}
				function load() {
					try {
						const s = JSON.parse(localStorage.getItem(SAVE_KEY));
						if (!s || !s.g || s.g.length !== WC * WR) return false;
						G = Uint8Array.from(s.g);
						inv = s.inv; diamonds = s.d || 0; praised = !!s.p;
						genPlayerAt(s.x, s.y);
						return true;
					} catch { return false; }
				}
				function genPlayerAt(x, y) {
					player = {x, y, vx: 0, vy: 0, w: 14, h: 36, face: 1, onG: false};
				}

				// --- inventory UI ---
				function renderHotbar() {
					hotbarEl.innerHTML = '';
					PLACEABLE.forEach((id) => {
						const b = document.createElement('button');
						b.type = 'button';
						b.className = 'slot' + (selected === id ? ' sel' : '');
						b.innerHTML = `<span class="chip" style="background:${BLOCKS[id].ore || BLOCKS[id].top}"></span>` +
							`<span class="cnt">${inv[id] || 0}</span>`;
						b.title = BLOCKS[id].n;
						b.addEventListener('click', () => {
							selected = id;
							mode = 'place';
							updateModeBtn();
							renderHotbar();
						});
						hotbarEl.appendChild(b);
					});
					diaEl.textContent = diamonds;
				}
				function updateModeBtn() {
					modeBtn.textContent = mode === 'dig' ? '⛏️ 캐기' : '🧱 놓기: ' + BLOCKS[selected].n;
				}
				modeBtn.addEventListener('click', () => {
					mode = mode === 'dig' ? 'place' : 'dig';
					updateModeBtn();
				});
				resetBtn.addEventListener('click', () => {
					if (!confirm('정말 새 세계를 만들까요? 지금 세계는 사라집니다.')) return;
					genWorld();
					renderHotbar();
					save();
				});
				okBtn.addEventListener('click', () => overlay.classList.add('hidden'));

				// --- dig & place ---
				function inReach(c, r) {
					const px = player.x + player.w / 2, py = player.y + player.h / 2;
					const dx = (c + 0.5) * TILE - px, dy = (r + 0.5) * TILE - py;
					return dx * dx + dy * dy < (TILE * 3.4) * (TILE * 3.4);
				}
				function overlapsPlayer(c, r) {
					return (c + 1) * TILE > player.x && c * TILE < player.x + player.w &&
						(r + 1) * TILE > player.y && r * TILE < player.y + player.h;
				}
				function dig(c, r) {
					const id = tileAt(c, r);
					if (id === AIR || id === BEDROCK || !inReach(c, r)) return false;
					G[idx(c, r)] = AIR;
					const drop = BLOCKS[id].drop || id;
					inv[drop] = (inv[drop] || 0) + 1;
					for (let i = 0; i < 7; i++)
						fx.push({x: (c + 0.5) * TILE, y: (r + 0.5) * TILE, vx: (Math.random() - 0.5) * 3,
							vy: -Math.random() * 2.5, life: 1, color: BLOCKS[id].ore || BLOCKS[id].top});
					if (id >= 7 && id <= 10) { sndOre(); } else sndDig(id);
					if (id === 10) {
						diamonds++;
						sndDia();
						if (diamonds >= 3 && !praised) {
							praised = true;
							setTimeout(() => overlay.classList.remove('hidden'), 500);
						}
					}
					renderHotbar();
					return true;
				}
				function place(c, r) {
					if (tileAt(c, r) !== AIR || !inReach(c, r) || overlapsPlayer(c, r)) return false;
					if ((inv[selected] || 0) <= 0) return false;
					G[idx(c, r)] = selected;
					inv[selected]--;
					sndPlace();
					renderHotbar();
					return true;
				}

				// --- physics ---
				function step(dt) {
					const k = dt / 16;
					const SPEED = 2.5, GRAV = 0.48, JUMP = -8.6;
					player.vx = 0;
					if (input.left) { player.vx = -SPEED; player.face = -1; }
					if (input.right) { player.vx = SPEED; player.face = 1; }
					if (input.jump && player.onG) { player.vy = JUMP; player.onG = false; sndJump(); }
					player.vy = Math.min(10, player.vy + GRAV * k);

					// X축
					player.x += player.vx * k;
					if (player.vx !== 0) {
						const dirC = player.vx > 0 ? Math.floor((player.x + player.w) / TILE) : Math.floor(player.x / TILE);
						for (let r = Math.floor(player.y / TILE); r <= Math.floor((player.y + player.h - 1) / TILE); r++) {
							if (solid(tileAt(dirC, r))) {
								player.x = player.vx > 0 ? dirC * TILE - player.w - 0.01 : (dirC + 1) * TILE + 0.01;
								break;
							}
						}
					}
					// Y축
					player.y += player.vy * k;
					player.onG = false;
					const dirR = player.vy > 0 ? Math.floor((player.y + player.h) / TILE) : Math.floor(player.y / TILE);
					for (let c = Math.floor(player.x / TILE); c <= Math.floor((player.x + player.w - 1) / TILE); c++) {
						if (solid(tileAt(c, dirR))) {
							if (player.vy > 0) { player.y = dirR * TILE - player.h - 0.01; player.onG = true; }
							else player.y = (dirR + 1) * TILE + 0.01;
							player.vy = 0;
							break;
						}
					}
					player.x = Math.max(0, Math.min(WPX - player.w, player.x));
					player.y = Math.max(0, Math.min(HPX - player.h, player.y));

					camX = Math.max(0, Math.min(WPX - VW, player.x + player.w / 2 - VW / 2));
					camY = Math.max(0, Math.min(HPX - VH, player.y + player.h / 2 - VH / 2));

					for (let i = fx.length - 1; i >= 0; i--) {
						const p = fx[i];
						p.x += p.vx * k; p.y += p.vy * k; p.vy += 0.25 * k; p.life -= dt / 450;
						if (p.life <= 0) fx.splice(i, 1);
					}

					saveCd -= dt;
					if (saveCd <= 0) { saveCd = 8000; save(); }
				}

				// --- render ---
				function draw(t) {
					// 밤하늘 배경
					const grd = ctx.createLinearGradient(0, 0, 0, VH);
					grd.addColorStop(0, '#0b0e1c');
					grd.addColorStop(1, '#101528');
					ctx.fillStyle = grd;
					ctx.fillRect(0, 0, VW, VH);
					ctx.fillStyle = 'rgba(255,255,255,0.5)';
					for (let i = 0; i < 26; i++) {
						const sx = ((i * 97 + 31) % WPX - camX * 0.4 % WPX + WPX) % WPX;
						if (sx < VW) ctx.fillRect(sx, (i * 53) % (VH * 0.5), 1.6, 1.6);
					}

					const c0 = Math.floor(camX / TILE), c1 = Math.ceil((camX + VW) / TILE);
					const r0 = Math.floor(camY / TILE), r1 = Math.ceil((camY + VH) / TILE);
					for (let r = r0; r < r1; r++)
						for (let c = c0; c < c1; c++) {
							const id = tileAt(c, r);
							if (id === AIR) continue;
							const B = BLOCKS[id];
							const x = c * TILE - camX, y = r * TILE - camY;
							ctx.fillStyle = B.body;
							ctx.fillRect(x, y, TILE, TILE);
							// 윗면 하이라이트(위가 비어있을 때)
							if (!solid(tileAt(c, r - 1))) {
								ctx.fillStyle = B.top;
								ctx.fillRect(x, y, TILE, 4);
							}
							// 광석 알갱이
							if (B.ore) {
								ctx.fillStyle = B.ore;
								ctx.fillRect(x + 4, y + 7, 4, 4);
								ctx.fillRect(x + 12, y + 12, 4, 4);
								ctx.fillRect(x + 11, y + 4, 3, 3);
								if (id === 10) { // 다이아 반짝
									ctx.globalAlpha = 0.5 + 0.5 * Math.sin(t / 200 + c * 3);
									ctx.fillRect(x + 6, y + 13, 3, 3);
									ctx.globalAlpha = 1;
								}
							}
							ctx.strokeStyle = 'rgba(0,0,0,0.25)';
							ctx.strokeRect(x + 0.5, y + 0.5, TILE - 1, TILE - 1);
						}

					// 조준 가능 범위 표시(마우스 근처는 생략, 캐릭터 주변 은은한 링)
					// 플레이어
					const px = player.x - camX, py = player.y - camY;
					ctx.save();
					// 몸통
					ctx.fillStyle = '#3ef58b';
					ctx.shadowColor = '#3ef58b';
					ctx.shadowBlur = 10;
					ctx.fillRect(px + 2, py + 14, player.w - 4, 16);
					// 머리
					ctx.fillStyle = '#ffd9a0';
					ctx.shadowBlur = 4;
					ctx.fillRect(px + 1, py, player.w - 2, 13);
					// 눈(바라보는 방향)
					ctx.fillStyle = '#20242c';
					ctx.fillRect(px + (player.face > 0 ? 8 : 3), py + 4, 2.6, 3.4);
					// 다리
					ctx.fillStyle = '#2a8f57';
					const walk = Math.abs(player.vx) > 0.1 ? Math.sin(t / 90) * 3 : 0;
					ctx.fillRect(px + 2, py + 30, 4, 6 + walk);
					ctx.fillRect(px + player.w - 6, py + 30, 4, 6 - walk);
					ctx.restore();

					// 파티클
					fx.forEach((p) => {
						ctx.globalAlpha = Math.max(0, p.life);
						ctx.fillStyle = p.color;
						ctx.fillRect(p.x - camX - 2, p.y - camY - 2, 4, 4);
						ctx.globalAlpha = 1;
					});
				}

				function loop(t) {
					const dt = lastT ? Math.min(50, t - lastT) : 16;
					lastT = t;
					step(dt);
					draw(t);
					raf = requestAnimationFrame(loop);
				}

				// --- input ---
				const input = {left: false, right: false, jump: false};
				const kmap = {a: 'left', d: 'right', A: 'left', D: 'right', ArrowLeft: 'left', ArrowRight: 'right',
					w: 'jump', W: 'jump', ' ': 'jump', ArrowUp: 'jump'};
				document.addEventListener('keydown', (e) => {
					if (kmap[e.key]) { e.preventDefault(); input[kmap[e.key]] = true; }
				});
				document.addEventListener('keyup', (e) => { if (kmap[e.key]) input[kmap[e.key]] = false; });
				[['btnL', 'left'], ['btnR', 'right'], ['btnJ', 'jump']].forEach(([id, k]) => {
					const b = document.getElementById(id);
					const on = (e) => { e.preventDefault(); input[k] = true; };
					const off = () => { input[k] = false; };
					b.addEventListener('pointerdown', on);
					b.addEventListener('pointerup', off);
					b.addEventListener('pointerleave', off);
					b.addEventListener('pointercancel', off);
				});

				function canvasTile(e) {
					const rect = canvas.getBoundingClientRect();
					const x = ((e.clientX - rect.left) / rect.width) * VW + camX;
					const y = ((e.clientY - rect.top) / rect.height) * VH + camY;
					return {c: Math.floor(x / TILE), r: Math.floor(y / TILE)};
				}
				canvas.addEventListener('pointerdown', (e) => {
					e.preventDefault();
					const {c, r} = canvasTile(e);
					// PC: 우클릭=놓기 / 좌클릭=캐기, 모바일: 모드 버튼 따름
					if (e.pointerType === 'mouse') {
						if (e.button === 2) place(c, r);
						else dig(c, r);
					} else {
						mode === 'dig' ? dig(c, r) : place(c, r);
					}
				});
				canvas.addEventListener('contextmenu', (e) => e.preventDefault());

				window.addEventListener('visibilitychange', () => { if (document.hidden) save(); });

				// --- boot ---
				if (!load()) genWorld();
				renderHotbar();
				updateModeBtn();
				raf = requestAnimationFrame(loop);

				// test hook
				window.__craft = {
					tile: (c, r) => tileAt(c, r),
					dig, place,
					inv: () => ({...inv}),
					player: () => ({...player}),
					setPlayer: (x, y) => { player.x = x; player.y = y; player.vy = 0; },
					setSelected: (id) => { selected = id; },
					diamonds: () => diamonds,
					tick: (dt) => { step(dt || 16); draw(performance.now()); },
					save, load,
				};
			})();
		</script>
	</body>
</html>

