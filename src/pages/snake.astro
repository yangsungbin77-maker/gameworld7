---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = '네온 스네이크 (Neon Snake) — 게임월드7';
const description =
	'네온 그리드 위를 달리는 클래식 스네이크 게임. 오브를 먹을수록 길어지고 빨라진다. 벽과 몸통을 피해 최고 기록에 도전하세요! 무료 · 설치 없음.';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div id="snakegame">
				<section class="game-hero">
					<span class="tag">PLAY · 미니게임</span>
					<h1>🐍 <span class="neon">네온 스네이크</span></h1>
					<p class="lead">오브를 먹으면 <strong>길어지고 빨라집니다</strong>. 벽과 자기 몸을 피해 최대한 오래 살아남으세요!</p>
				</section>

				<div class="hud">
					<div class="hud-item">점수 <strong id="score">0</strong></div>
					<div class="hud-item">최고 기록 <strong id="best">0</strong></div>
				</div>

				<div class="stage">
					<canvas id="board" width="480" height="480" aria-label="네온 스네이크 게임 보드"></canvas>
					<div class="overlay" id="overlay">
						<h2 id="ov-title">네온 스네이크</h2>
						<p id="ov-sub">방향키·스와이프로 이동</p>
						<button class="btn" id="startBtn" type="button">게임 시작</button>
						<button class="btn-ghost btn" id="shareBtn" type="button" hidden>점수 공유</button>
					</div>
				</div>

				<div class="dpad" aria-label="모바일 방향 버튼">
					<button type="button" data-dir="up" aria-label="위">▲</button>
					<div class="dpad-mid">
						<button type="button" data-dir="left" aria-label="왼쪽">◀</button>
						<button type="button" data-dir="down" aria-label="아래">▼</button>
						<button type="button" data-dir="right" aria-label="오른쪽">▶</button>
					</div>
				</div>

				<section class="howto">
					<h2>조작법</h2>
					<ul>
						<li><strong>PC</strong> — 방향키 또는 W·A·S·D로 이동합니다.</li>
						<li><strong>모바일</strong> — 화면을 스와이프하거나 아래 방향 버튼을 누릅니다.</li>
						<li>마젠타 오브를 먹으면 10점을 얻고 몸이 한 칸 길어집니다.</li>
						<li>벽이나 자기 몸에 부딪히면 게임 오버. 먹을수록 속도가 빨라집니다.</li>
					</ul>
					<h2>짧은 팁</h2>
					<ul>
						<li>가장자리를 크게 도는 습관을 들이면 후반에 몸이 길어져도 갇히지 않습니다.</li>
						<li>오브가 벽에 붙어 나오면 급하게 꺾지 말고 한 바퀴 돌아 진입 각도를 만드세요.</li>
						<li>속도가 빨라진 뒤에는 세 칸 앞을 미리 보고 조작하는 게 핵심입니다.</li>
					</ul>
				</section>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const canvas = document.getElementById('board');
				const ctx = canvas.getContext('2d');
				const N = 24; // grid cells
				const CELL = canvas.width / N;
				const scoreEl = document.getElementById('score');
				const bestEl = document.getElementById('best');
				const overlay = document.getElementById('overlay');
				const ovTitle = document.getElementById('ov-title');
				const ovSub = document.getElementById('ov-sub');
				const startBtn = document.getElementById('startBtn');
				const shareBtn = document.getElementById('shareBtn');
				const BEST_KEY = 'gw7_snake_best';

				let snake, dir, nextDir, food, score, dead, stepMs, acc, last, raf;
				let best = Number(localStorage.getItem(BEST_KEY) || 0);
				bestEl.textContent = best;

				function reset() {
					snake = [ {x: 8, y: 12}, {x: 7, y: 12}, {x: 6, y: 12} ];
					dir = {x: 1, y: 0};
					nextDir = dir;
					score = 0;
					dead = false;
					stepMs = 140;
					acc = 0;
					last = 0;
					scoreEl.textContent = '0';
					spawnFood();
				}

				function spawnFood() {
					do {
						food = {x: Math.floor(Math.random() * N), y: Math.floor(Math.random() * N)};
					} while (snake.some((s) => s.x === food.x && s.y === food.y));
				}

				function setDir(d) {
					const m = {up: {x: 0, y: -1}, down: {x: 0, y: 1}, left: {x: -1, y: 0}, right: {x: 1, y: 0}}[d];
					if (!m) return;
					if (m.x === -dir.x && m.y === -dir.y) return; // no 180 turn
					nextDir = m;
				}

				function step() {
					dir = nextDir;
					const head = {x: snake[0].x + dir.x, y: snake[0].y + dir.y};
					if (head.x < 0 || head.y < 0 || head.x >= N || head.y >= N ||
						snake.some((s) => s.x === head.x && s.y === head.y)) {
						return gameOver();
					}
					snake.unshift(head);
					if (head.x === food.x && head.y === food.y) {
						score += 10;
						scoreEl.textContent = score;
						stepMs = Math.max(60, stepMs - 3);
						spawnFood();
					} else {
						snake.pop();
					}
				}

				function draw(t) {
					ctx.fillStyle = '#0b0e14';
					ctx.fillRect(0, 0, canvas.width, canvas.height);
					// grid
					ctx.strokeStyle = 'rgba(62,245,139,0.06)';
					ctx.lineWidth = 1;
					for (let i = 1; i < N; i++) {
						ctx.beginPath(); ctx.moveTo(i * CELL, 0); ctx.lineTo(i * CELL, canvas.height); ctx.stroke();
						ctx.beginPath(); ctx.moveTo(0, i * CELL); ctx.lineTo(canvas.width, i * CELL); ctx.stroke();
					}
					// food (pulsing magenta orb)
					const pulse = 0.72 + 0.28 * Math.sin(t / 180);
					ctx.save();
					ctx.shadowColor = '#ff2fb3';
					ctx.shadowBlur = 18 * pulse;
					ctx.fillStyle = '#ff2fb3';
					ctx.beginPath();
					ctx.arc((food.x + 0.5) * CELL, (food.y + 0.5) * CELL, CELL * 0.34 * pulse + CELL * 0.06, 0, Math.PI * 2);
					ctx.fill();
					ctx.restore();
					// snake
					ctx.save();
					ctx.shadowColor = '#3ef58b';
					snake.forEach((s, i) => {
						const k = 1 - i / (snake.length + 4);
						ctx.shadowBlur = i === 0 ? 16 : 8;
						ctx.fillStyle = i === 0 ? '#b9ffd6' : `rgba(62,245,139,${0.45 + 0.55 * k})`;
						const pad = CELL * 0.1;
						ctx.beginPath();
						ctx.roundRect(s.x * CELL + pad, s.y * CELL + pad, CELL - pad * 2, CELL - pad * 2, CELL * 0.28);
						ctx.fill();
					});
					ctx.restore();
				}

				function loop(t) {
					if (dead) return;
					if (!last) last = t;
					acc += t - last;
					last = t;
					while (acc >= stepMs && !dead) { acc -= stepMs; step(); }
					draw(t);
					raf = requestAnimationFrame(loop);
				}

				function gameOver() {
					dead = true;
					cancelAnimationFrame(raf);
					if (score > best) {
						best = score;
						localStorage.setItem(BEST_KEY, best);
						bestEl.textContent = best;
					}
					ovTitle.textContent = '게임 오버!';
					ovSub.textContent = `점수 ${score} · 최고 기록 ${best}`;
					startBtn.textContent = '다시 하기';
					shareBtn.hidden = false;
					overlay.classList.remove('hidden');
				}

				startBtn.addEventListener('click', () => {
					overlay.classList.add('hidden');
					reset();
					last = 0;
					raf = requestAnimationFrame(loop);
				});

				shareBtn.addEventListener('click', async () => {
					const text = `네온 스네이크에서 ${score}점! 나를 이겨봐 👉 ${location.href}`;
					try {
						await navigator.clipboard.writeText(text);
						shareBtn.textContent = '복사 완료!';
					} catch {
						shareBtn.textContent = text;
					}
					setTimeout(() => (shareBtn.textContent = '점수 공유'), 1600);
				});

				document.addEventListener('keydown', (e) => {
					const map = {
						ArrowUp: 'up', ArrowDown: 'down', ArrowLeft: 'left', ArrowRight: 'right',
						w: 'up', s: 'down', a: 'left', d: 'right',
						W: 'up', S: 'down', A: 'left', D: 'right',
					};
					if (map[e.key]) { e.preventDefault(); setDir(map[e.key]); }
				});

				document.querySelectorAll('.dpad [data-dir]').forEach((b) =>
					b.addEventListener('click', () => setDir(b.dataset.dir)),
				);

				let touchStart = null;
				canvas.addEventListener('touchstart', (e) => {
					touchStart = e.touches[0];
				}, {passive: true});
				canvas.addEventListener('touchmove', (e) => e.preventDefault(), {passive: false});
				canvas.addEventListener('touchend', (e) => {
					if (!touchStart) return;
					const dx = e.changedTouches[0].clientX - touchStart.clientX;
					const dy = e.changedTouches[0].clientY - touchStart.clientY;
					if (Math.max(Math.abs(dx), Math.abs(dy)) < 18) return;
					if (Math.abs(dx) > Math.abs(dy)) setDir(dx > 0 ? 'right' : 'left');
					else setDir(dy > 0 ? 'down' : 'up');
					touchStart = null;
				});

				draw(0);
			})();
		</script>
	</body>
</html>

<style>
	#snakegame { max-width: 560px; margin: 0 auto; }
	.game-hero { padding: 2rem 0 1.4rem; text-align: center; }
	.game-hero h1 { font-size: clamp(1.9rem, 5vw, 2.6rem); margin: 0.5rem 0; }
	.neon { color: var(--accent); text-shadow: 0 0 24px var(--accent-glow); }
	.lead { color: var(--text-muted); }

	.hud {
		display: flex; justify-content: center; gap: 1rem; margin-bottom: 0.9rem;
	}
	.hud-item {
		background: var(--bg-elev); border: 1px solid var(--border); border-radius: 999px;
		padding: 0.4em 1.1em; color: var(--text-muted); font-size: 0.92rem; font-weight: 600;
	}
	.hud-item strong { color: var(--accent); margin-left: 0.35em; }

	.stage { position: relative; }
	#board {
		display: block; width: 100%; height: auto; touch-action: none;
		background: #0b0e14; border: 1px solid var(--border); border-radius: var(--radius);
		box-shadow: 0 0 40px rgba(62, 245, 139, 0.08);
	}
	.overlay {
		position: absolute; inset: 0; display: flex; flex-direction: column;
		align-items: center; justify-content: center; gap: 0.7rem;
		background: rgba(11, 14, 20, 0.82); backdrop-filter: blur(4px);
		border-radius: var(--radius); text-align: center; padding: 1rem;
	}
	.overlay.hidden { display: none; }
	.overlay h2 { margin: 0; font-size: 1.7rem; }
	.overlay p { margin: 0; color: var(--text-muted); }

	.dpad { margin: 1rem auto 0; width: max-content; display: none; }
	.dpad button {
		width: 56px; height: 48px; margin: 3px; border-radius: 12px;
		background: var(--bg-elev); border: 1px solid var(--border); color: var(--accent);
		font-size: 1.1rem; cursor: pointer;
	}
	.dpad button:active { background: rgba(62, 245, 139, 0.15); }
	.dpad-mid { display: flex; justify-content: center; }
	.dpad > button { display: block; margin-inline: auto; }
	@media (pointer: coarse) { .dpad { display: block; } }

	.howto { margin: 2.2rem 0 3rem; }
	.howto h2 { font-size: 1.25rem; margin: 1.4rem 0 0.6rem; }
	.howto ul { color: var(--text-muted); padding-left: 1.2em; }
	.howto li { margin-bottom: 0.35em; }
</style>
